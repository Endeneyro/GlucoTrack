@using GlucoTrack.Shared.DTOs.Sync
@using GlucoTrack.Client.Services
@using System.Text.Json
@inject HttpClient Http
@inject DbService Db
@inject ConnectivityService Connectivity
@inject IJSRuntime JS

<div class="modal-backdrop">
    <div class="modal-card modal-card-wide" @onclick:stopPropagation style="max-width:640px">
        @if (_catDropdownOpen)
        {
            <div style="position:fixed;inset:0;z-index:9" @onclick="() => _catDropdownOpen = false"></div>
        }
        <div class="modal-header">
            <span class="modal-title">Выбор продукта</span>
            <button class="modal-close" @onclick="() => OnClose.InvokeAsync()">✕</button>
        </div>

        <div class="form-group" style="margin-bottom:.75rem">
            <input class="form-control" type="text" placeholder="Поиск по названию..."
                   value="@_search" @oninput="OnSearchInput" autofocus />
        </div>

        <div style="display:flex;flex-wrap:wrap;gap:.5rem;align-items:center;margin-bottom:.5rem">
            <button class="filter-button @(_filter == 3 ? "active" : "")" @onclick="() => SetFilter(3)">Мои</button>
            <button class="filter-button @(_filter == 1 ? "active" : "")" @onclick="() => SetFilter(1)">Избранные</button>
            <button class="filter-button @(_filter == 2 ? "active" : "")" @onclick="() => SetFilter(2)">Часто используемые</button>
            <div style="position:relative" @onclick:stopPropagation>
                <button id="catalog-cat-btn" class="filter-button @(_catFilter.HasValue ? "active" : "")" @onclick="ToggleCatDropdownAsync">
                    @(_catFilter.HasValue ? $"Категория: {ProductCategories.Label(_catFilter.Value)}" : "Категории") ▾
                </button>
                @if (_catDropdownOpen)
                {
                    <div class="action-dropdown" style="position:fixed;min-width:190px;top:@(_catDropdownTop.ToString("F0"))px;left:@(_catDropdownLeft.ToString("F0"))px;z-index:10000">
                        <button @onclick="() => SelectCategory(null)">Все категории</button>
                        @foreach (var (val, lbl) in ProductCategories.All)
                        {
                            var v = val;
                            <button @onclick="() => SelectCategory(v)">
                                <span style="display:flex;align-items:center;gap:.5rem">
                                    <img src="icons/@(ProductCategories.IconName(v)).svg" width="20" height="20" />@lbl
                                </span>
                            </button>
                        }
                    </div>
                }
            </div>
        </div>

        <div style="display:flex;flex-wrap:wrap;gap:.5rem;margin-bottom:.875rem">
            <button class="filter-button @(_filter == 5 ? "active" : "")" @onclick="() => SetFilter(5)">Базовые</button>
            <button class="filter-button @(_filter == 4 ? "active" : "")" @onclick="() => SetFilter(4)">От сообщества</button>
        </div>

        <div style="max-height:55vh;overflow-y:auto;display:flex;flex-direction:column;gap:.5rem">
            @if ((_filter == 4 || _filter == 5) && !Connectivity.IsOnline)
            {
                <div style="text-align:center;padding:2rem;color:var(--c-text-muted)">
                    <div>Нет соединения с интернетом.</div>
                    <div style="font-size:.82rem">Этот раздел требует доступа к серверу.</div>
                </div>
            }
            else if ((_filter == 2 && _frequentLoading) || ((_filter == 4 || _filter == 5) && _remoteLoading))
            {
                <p style="color:var(--c-text-muted);padding:1rem 0">Загрузка...</p>
            }
            else if ((_filter == 4 || _filter == 5) && _remoteError)
            {
                <div style="text-align:center;padding:2rem;color:var(--c-text-muted)">
                    <div>Не удалось загрузить данные.</div>
                    <div style="font-size:.82rem">Проверьте соединение и попробуйте снова.</div>
                    <button class="btn btn-ghost btn-sm" style="margin-top:.75rem" @onclick="LoadRemoteAsync">Повторить</button>
                </div>
            }
            else
            {
            var filtered = GetFiltered();
            @if (filtered.Count == 0)
            {
                <div style="text-align:center;padding:2rem;color:var(--c-text-muted)">Ничего не найдено</div>
            }
            else
            {
                @foreach (var p in filtered)
                {
                    var expanded = _expandedId == p.Id;
                    <div class="home-card product-row-clickable" style="padding:.65rem 1rem" @onclick="() => SelectAndClose(p)">
                        <div style="display:flex;flex-wrap:wrap;align-items:center;gap:.6rem">
                            <div class="product-cat-icon" style="flex-shrink:0">
                                <img src="@(p.HasImage ? ProductImageUrl(p) : $"icons/{ProductCategories.IconName(p.Category)}.svg")"
                                     width="48" height="48" style="border-radius:50%;object-fit:cover"
                                     onerror="this.src='icons/@(ProductCategories.IconName(p.Category)).svg'" />
                            </div>
                            <div class="product-name-cell" style="flex:1 1 140px;min-width:0">
                                <span class="product-row-name">@p.Name</span>
                                @if (!string.IsNullOrEmpty(p.Manufacturer))
                                { <span class="product-row-mfr">@p.Manufacturer</span> }
                            </div>
                            <span class="product-cat-badge" style="flex-shrink:0">@ProductCategories.Label(p.Category)</span>
                            <div class="product-row-num" style="flex-shrink:0;min-width:64px;text-align:center">@p.CaloriesPer100g.ToString("F0") ккал</div>
                            <div style="flex-shrink:0;display:flex;flex-direction:column;align-items:center;gap:0;line-height:1.15;font-size:.78rem;font-variant-numeric:tabular-nums;white-space:nowrap;width:2.4rem">
                                <span><span style="display:inline-block;width:.9rem;color:var(--c-protein);font-size:.68rem;font-weight:600">Б</span>@p.ProteinPer100g.ToString("F1")</span>
                                <span><span style="display:inline-block;width:.9rem;color:var(--c-fat);font-size:.68rem;font-weight:600">Ж</span>@p.FatPer100g.ToString("F1")</span>
                                <span><span style="display:inline-block;width:.9rem;color:var(--c-carbs);font-size:.68rem;font-weight:600">У</span>@p.CarbsPer100g.ToString("F1")</span>
                            </div>
                            <button class="row-action-btn" title="Подробнее" style="flex-shrink:0"
                                    @onclick:stopPropagation @onclick="() => ToggleExpand(p.Id)">
                                <span style="font-size:.8rem;color:var(--c-text-muted)">@(expanded ? "▾" : "▸")</span>
                            </button>
                        </div>
                        @if (expanded)
                        {
                            <div style="margin-top:.65rem;padding-top:.65rem;border-top:1px solid var(--c-border);display:flex;gap:1.25rem" @onclick:stopPropagation>
                                <img src="@(p.HasImage ? ProductImageUrl(p) : $"icons/{ProductCategories.IconName(p.Category)}.svg")"
                                     alt="" style="width:90px;height:90px;border-radius:12px;object-fit:cover;background:var(--c-bg);flex-shrink:0"
                                     onerror="this.src='icons/@(ProductCategories.IconName(p.Category)).svg'" />
                                <div style="flex:1;min-width:0;font-size:.85rem">
                                    <div style="display:flex;flex-wrap:wrap;gap:1rem;margin-bottom:.5rem">
                                        <span>Клетчатка: <b>@p.FiberPer100g.ToString("F1")</b> г</span>
                                        @if (p.GlycemicIndex.HasValue)
                                        { <span>ГИ: <b>@p.GlycemicIndex</b></span> }
                                    </div>
                                    @{ var micros = ProductNutritionInfo.GetMicronutrients(p); }
                                    @if (micros.Count > 0)
                                    {
                                        <div style="display:flex;flex-wrap:wrap;gap:.5rem .9rem;color:var(--c-text-muted)">
                                            @foreach (var (label, value) in micros)
                                            {
                                                <span>@label: <b style="color:var(--c-text)">@value.ToString("F1")</b></span>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <div style="color:var(--c-text-muted)">Подробных данных о витаминах и минералах нет.</div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
            }
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public List<ProductDto> Products { get; set; } = [];
    [Parameter] public EventCallback<ProductDto> OnSelect { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    private string _search = "";
    private int? _catFilter;
    private bool _catDropdownOpen;
    private double _catDropdownTop, _catDropdownLeft;
    private int _filter = 3; // 1=Избранные 2=Часто используемые 3=Мои (default) 4=От сообщества 5=Базовые
    private HashSet<Guid> _favoriteIds = [];
    private List<ProductDto> _frequent = [];
    private bool _frequentLoading;
    private List<ProductDto> _remote = [];
    private bool _remoteLoading, _remoteError;
    private Guid? _expandedId;

    private void ToggleExpand(Guid id) => _expandedId = _expandedId == id ? null : id;

    private async Task ToggleCatDropdownAsync()
    {
        if (_catDropdownOpen) { _catDropdownOpen = false; return; }
        try
        {
            var rect = await JS.InvokeAsync<JsonElement>("getBoundingRectLeft", "catalog-cat-btn");
            _catDropdownTop = rect.GetProperty("top").GetDouble() + 4;
            _catDropdownLeft = rect.GetProperty("left").GetDouble();
        }
        catch { _catDropdownTop = 100; _catDropdownLeft = 16; }
        _catDropdownOpen = true;
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var favs = await Http.GetFromJsonAsync<List<ProductDto>>("/api/products/favorites");
            _favoriteIds = (favs ?? []).Select(p => p.Id).ToHashSet();
        }
        catch { }
    }

    private async Task SetFilter(int f)
    {
        _filter = f;
        if (f == 2 && _frequent.Count == 0)
        {
            _frequentLoading = true;
            try
            {
                var result = await Http.GetFromJsonAsync<List<ProductSearchItemDto>>("/api/products/search?source=mine&q=&take=100");
                _frequent = (result ?? []).Where(r => r.UseCount > 0).OrderByDescending(r => r.UseCount).Select(r => r.Product).ToList();
            }
            catch { _frequent = []; }
            _frequentLoading = false;
        }
        else if (f == 4 || f == 5)
        {
            await LoadRemoteAsync();
        }
    }

    private async Task OnSearchInput(ChangeEventArgs e)
    {
        _search = e.Value?.ToString() ?? "";
        if (_filter == 4 || _filter == 5) await LoadRemoteAsync();
    }

    private async Task LoadRemoteAsync()
    {
        if (!Connectivity.IsOnline) { _remote = []; return; }
        _remoteLoading = true;
        _remoteError = false;
        try
        {
            var src = _filter == 4 ? "shared" : "base";
            var url = $"/api/products/search?source={src}&q={Uri.EscapeDataString(_search)}&take=100";
            var result = await Http.GetFromJsonAsync<List<ProductSearchItemDto>>(url);
            _remote = (result ?? []).Select(r => r.Product).ToList();
        }
        catch { _remote = []; _remoteError = true; }
        _remoteLoading = false;
    }

    private void SelectCategory(int? val)
    {
        _catFilter = val;
        _catDropdownOpen = false;
    }

    private List<ProductDto> GetFiltered()
    {
        var source = _filter switch
        {
            1 => Products.Where(p => _favoriteIds.Contains(p.Id)),
            2 => _frequent.AsEnumerable(),
            4 or 5 => _remote.AsEnumerable(),
            _ => Products.AsEnumerable()
        };
        source = source.Where(p => !p.IsDeleted);
        if (_catFilter.HasValue)
            source = source.Where(p => p.Category == _catFilter.Value);
        // Server already filters "От сообщества"/"Базовые" by q; re-filtering client-side
        // is harmless and keeps the other tabs (local data) working the same way.
        if (!string.IsNullOrWhiteSpace(_search))
            source = source.Where(p => p.Name.Contains(_search, StringComparison.OrdinalIgnoreCase)
                                    || (!string.IsNullOrEmpty(p.Manufacturer) && p.Manufacturer.Contains(_search, StringComparison.OrdinalIgnoreCase)));
        return source.OrderBy(p => p.Name).Take(100).ToList();
    }

    private async Task SelectAndClose(ProductDto p)
    {
        var toSelect = p;
        if (_filter == 4 || _filter == 5)
        {
            // Picking a base/community product directly — transparently create/reuse a
            // resilient private copy so it keeps working offline and survives the source
            // product being deleted, un-shared, or unreachable.
            try
            {
                var resp = await Http.PostAsync($"/api/products/{p.Id}/ensure-clone", null);
                if (resp.IsSuccessStatusCode)
                {
                    var resolved = await resp.Content.ReadFromJsonAsync<ProductDto>();
                    if (resolved is not null)
                    {
                        toSelect = resolved;
                        await Db.PutAsync("products", resolved, pending: false);
                    }
                }
            }
            catch { }
        }
        await OnSelect.InvokeAsync(toSelect);
        await OnClose.InvokeAsync();
    }

    private static string ProductImageUrl(ProductDto p) => $"/api/products/{p.Id}/image?v={p.UpdatedAtUtc.Ticks}";
}
