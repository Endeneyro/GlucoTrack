@page "/calendar"
@attribute [Authorize]
@using GlucoTrack.Client.Models
@using GlucoTrack.Shared.DTOs.Sync
@using GlucoTrack.Shared.Events
@inject DbService Db
@inject SyncService Sync
@inject NavigationManager Nav
@inject ToastService Toasts
@implements IDisposable

<PageTitle>Календарь — GlucoTrack</PageTitle>

<div class="calendar-page">
    <!-- ── Header ──────────────────────────────────────────────────── -->
    <div style="margin-bottom:1.25rem">
        <h2 style="margin:0;font-size:1.35rem;font-weight:700;color:var(--c-text)">Календарь</h2>
        <p style="margin:.15rem 0 0;font-size:.85rem;color:var(--c-text-muted)">Дневник и план событий по дням</p>
    </div>

  <div style="max-width:860px;margin:0 auto">
    <!-- Month navigation -->
    <div class="home-date-bar" style="justify-content:space-between">
        <button class="btn btn-ghost btn-icon" @onclick="PrevMonth">‹</button>
        <span style="font-size:1.1rem;font-weight:600">@_month.ToString("MMMM yyyy", _ru)</span>
        <button class="btn btn-ghost btn-icon" @onclick="NextMonth">›</button>
    </div>

    <!-- Calendar grid -->
    <div class="cal-grid">
        <div class="cal-dow">
            @for (var i = 0; i < _dayHeaders.Length; i++)
            {
                var isWeekendHeader = i == 5 || i == 6;
                <div class="cal-dow-cell@(isWeekendHeader ? " cal-dow-cell-weekend" : "")">@_dayHeaders[i]</div>
            }
        </div>
        <div class="cal-days">
            @foreach (var day in _calDays)
            {
                var isToday    = day == DateOnly.FromDateTime(DateTime.Today);
                var isSelected = day == _selected;
                var inMonth    = day.Month == _month.Month;
                var hasPlan    = _eventsByDate.ContainsKey(day);
                var isWeekend  = day.DayOfWeek is DayOfWeek.Saturday or DayOfWeek.Sunday;
                var cls = "cal-day" +
                          (isToday    ? " cal-day-today"    : "") +
                          (isSelected ? " cal-day-selected" : "") +
                          (!inMonth   ? " cal-day-other-month" : "") +
                          (isWeekend  ? " cal-day-weekend"   : "");
                <div class="@cls" @onclick="() => SelectDay(day)">
                    <div class="cal-day-num">@day.Day</div>
                    @if (inMonth)
                    {
                        <div class="cal-dots">
                            @if (hasPlan)
                            {
                                var types = _eventsByDate[day].Select(e => (PlannedEventType)e.EventType).Distinct().OrderBy(t => (int)t);
                                @foreach (var t in types)
                                { <div class="cal-dot @EventDotClass(t)"></div> }
                            }
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    <!-- Дневник дня -->
    <div class="home-card">
        <div class="home-card-title">
            Дневник дня · @_selected.ToString("d MMMM", _ru)
        </div>

        @if (_criticalLowGlucose.HasValue && _selected == DateOnly.FromDateTime(DateTime.Today))
        {
            <div style="background:#FEF2F2;border:2px solid #DC2626;border-radius:var(--r-md);padding:.75rem 1rem;margin-bottom:1rem;display:flex;align-items:center;gap:.75rem">
                <span style="font-size:1.3rem">🚨</span>
                <div style="flex:1;font-size:.875rem">
                    <div style="font-weight:700;color:#991B1B">Глюкоза @_criticalLowGlucose.Value.ToString("F1") ммоль/л — тяжёлая гипогликемия</div>
                    <div style="color:#B91C1C">Немедленно примите быстрые углеводы (сок, глюкоза, сахар — 15–20 г). Если не можете глотать или теряете сознание — нужна помощь / глюкагон. Инсулин не вводить. Перемерьте через 15 минут.</div>
                </div>
            </div>
        }
        else if (_lowGlucose.HasValue && _selected == DateOnly.FromDateTime(DateTime.Today))
        {
            <div style="background:#FEF3C7;border:1.5px solid #F59E0B;border-radius:var(--r-md);padding:.75rem 1rem;margin-bottom:1rem;display:flex;align-items:center;gap:.75rem">
                <span style="font-size:1.3rem">⚠️</span>
                <div style="flex:1;font-size:.875rem">
                    <div style="font-weight:600;color:#92400E">Глюкоза @_lowGlucose.Value.ToString("F1") ммоль/л — ниже нормы (гипогликемия)</div>
                    <div style="color:#B45309">Съешьте ~15 г быстрых углеводов (сок, глюкоза, сахар). Инсулин сейчас не вводить. Перемерьте через 15 минут.</div>
                </div>
            </div>
        }
        else if (_correctionDoneGlucose.HasValue && _selected == DateOnly.FromDateTime(DateTime.Today))
        {
            <div style="background:#F0FDF4;border:1.5px solid #86EFAC;border-radius:var(--r-md);padding:.75rem 1rem;margin-bottom:1rem;display:flex;align-items:center;gap:.75rem">
                <span style="font-size:1.3rem">✅</span>
                <div style="flex:1;font-size:.875rem">
                    <div style="font-weight:600;color:#166534">Коррекция введена — сахар был @_correctionDoneGlucose.Value.ToString("F1") ммоль/л</div>
                    <div style="color:#15803D">Инсулин уже на борту, повторный укол не нужен — дайте дозе подействовать. Перемерьте сахар через ~1 час.</div>
                </div>
            </div>
        }
        else if (_criticalGlucose.HasValue && _selected == DateOnly.FromDateTime(DateTime.Today))
        {
            <div style="background:#FEF2F2;border:1.5px solid #F87171;border-radius:var(--r-md);padding:.75rem 1rem;margin-bottom:1rem;display:flex;align-items:center;gap:.75rem">
                <span style="font-size:1.3rem">🚨</span>
                <div style="flex:1;font-size:.875rem">
                    <div style="font-weight:600;color:#991B1B">Глюкоза @_criticalGlucose.Value.ToString("F1") ммоль/л — критически высокая</div>
                    <div style="color:#B91C1C">Сделайте коррекционный укол сейчас, а приём пищи отодвиньте. Перед едой потом колите только дозу на углеводы.</div>
                </div>
                <button class="btn btn-sm" style="background:#DC2626;color:#fff;flex-shrink:0"
                        @onclick="() => GoToInsulinAlert(_criticalGlucose!.Value)">
                    Ввести коррекцию
                </button>
            </div>
        }
        else if (_alertGlucose.HasValue && _selected == DateOnly.FromDateTime(DateTime.Today))
        {
            <div style="background:#FEF3C7;border:1.5px solid #F59E0B;border-radius:var(--r-md);padding:.75rem 1rem;margin-bottom:1rem;display:flex;align-items:center;gap:.75rem">
                <span style="font-size:1.3rem">⚠️</span>
                <div style="flex:1;font-size:.875rem">
                    <div style="font-weight:600;color:#92400E">Глюкоза @_alertGlucose.Value.ToString("F1") ммоль/л — выше нормы</div>
                    <div style="color:#B45309">Рекомендуется коррекционный укол инсулина</div>
                </div>
                <button class="btn btn-sm" style="background:#F59E0B;color:#fff;flex-shrink:0"
                        @onclick="() => GoToInsulinAlert(_alertGlucose!.Value)">
                    Ввести инъекцию
                </button>
            </div>
        }
        else if (_pendingBolusTime.HasValue && _selected == DateOnly.FromDateTime(DateTime.Today))
        {
            <div style="background:#EFF6FF;border:1.5px solid #BFDBFE;border-radius:var(--r-md);padding:.75rem 1rem;margin-bottom:1rem;display:flex;align-items:center;gap:.75rem">
                <img src="icons/meals.svg" style="width:1.3rem;height:1.3rem" />
                <div style="flex:1;font-size:.875rem">
                    <div style="font-weight:600;color:#1e40af">Сахар выше нормы, но скоро плановый болюс в @_pendingBolusTime.Value.ToString("HH:mm")</div>
                    <div style="color:#1d4ed8">Коррекция будет учтена в нём — отдельную инъекцию делать не нужно, иначе инсулин «сложится».</div>
                </div>
            </div>
        }

        @if (_loading)
        { <p style="color:var(--c-text-muted);font-size:.875rem">Загрузка...</p> }
        else
        {
            var allItems = _diaryItems.OrderBy(i => i.Time).ToList();
            @if (allItems.Count == 0)
            {
                <div style="padding:2rem 0;text-align:center;color:var(--c-text-muted)">
                    <img src="icons/diary.svg" style="width:7.5rem;height:7.5rem;margin-bottom:.5rem;opacity:.6" />
                    <div style="font-size:.875rem">В этот день ничего не записано</div>
                </div>
            }
            else
            {
                <div class="diary-timeline">
                    @foreach (var item in allItems)
                    {
                        var actionable = IsActionable(item);
                        var itemCls = "diary-item " + DiaryCardBgClass(item) +
                            (item.IsPlanned && !item.IsDone ? " diary-item-planned" : "") +
                            (item.IsDone    ? " diary-item-done" : "") +
                            (actionable     ? " diary-item-clickable" : "");

                        <div class="@itemCls" @onclick="() => OnDiaryItemClick(item)">
                            <div class="diary-item-time">@item.Time.ToString("HH:mm")</div>
                            <div class="diary-item-icon @DiaryIconBgClass(item)">
                                <span class="diary-icon @DiaryIconColorClass(item)"
                                      style="-webkit-mask-image:url('@DiaryIconPath((PlannedEventType)item.EventType)');mask-image:url('@DiaryIconPath((PlannedEventType)item.EventType)')"></span>
                            </div>
                            <div class="diary-item-body">
                                <div class="diary-item-title">@item.Title</div>
                                @if (!string.IsNullOrEmpty(item.Sub))
                                { <div class="diary-item-sub">@item.Sub</div> }
                            </div>
                            @if (!string.IsNullOrEmpty(item.ResultText))
                            {
                                <div class="diary-item-result">✓ @item.ResultText</div>
                            }
                            @if (item.Protein.HasValue)
                            {
                                <div class="diary-item-macros">
                                    <span class="macro-pill-sm macro-pill-sm-protein"><span>Б</span>@item.Protein.Value.ToString("F0")</span>
                                    <span class="macro-pill-sm macro-pill-sm-fat"><span>Ж</span>@item.Fat!.Value.ToString("F0")</span>
                                    <span class="macro-pill-sm macro-pill-sm-carbs"><span>У</span>@item.Carbs!.Value.ToString("F0")</span>
                                </div>
                            }
                            @if (!item.IsDone && item.IsPlanned && (PlannedEventType)item.EventType == PlannedEventType.Activity && actionable)
                            {
                                <button class="btn btn-ghost btn-sm" style="flex-shrink:0"
                                        @onclick:stopPropagation="true"
                                        @onclick="() => MarkDoneAsync(item.EventId!.Value)">
                                    Выполнено
                                </button>
                            }
                            @if (item.IsPlanned && item.EventId is not null)
                            {
                                <button class="diary-item-edit-btn"
                                        title="Редактировать"
                                        @onclick:stopPropagation="true"
                                        @onclick="() => OpenEditModal(item.EventId.Value)">
                                    <img src="icons/edit.svg" width="18" height="18" />
                                </button>
                            }
                        </div>
                    }
                </div>
            }

            <!-- Bottom button -->
            <div style="margin-top:1rem;padding-top:1rem;border-top:1px solid var(--c-border)">
                @if (_selected >= DateOnly.FromDateTime(DateTime.Today))
                {
                    <div class="diary-plan-btn" @onclick="OpenModal">+ Запланировать событие</div>
                }
                else
                {
                    <div class="diary-plan-btn" style="color:var(--c-text-muted);border-color:var(--c-border)">+ Добавить</div>
                }
            </div>
        }
    </div>
  </div>
</div>

<PlanModal Visible="_modalOpen" Date="_selected" EditEvent="_editEvent"
           CurrentGlucose="_lastGlucose"
           OnClose="@CloseModal" OnSaved="@OnEventSaved" />

@if (_viewMealOpen && _viewMealEvent is not null)
{
    <div class="modal-backdrop" @onclick="() => _viewMealOpen = false">
        <div class="modal-card" @onclick:stopPropagation="true">
            <div class="modal-header">
                <div>
                    <div class="modal-title"><img src="icons/meals.svg" style="width:1.1rem;height:1.1rem;vertical-align:middle;margin-right:.35rem" />Приём пищи</div>
                    <div style="font-size:.82rem;color:var(--c-text-muted)">
                        @_viewMealEvent.PlannedAtUtc.ToLocalTime().ToString("HH:mm")
                        @if (!string.IsNullOrEmpty(_viewMealEvent.Note))
                        { <span> · @_viewMealEvent.Note</span> }
                    </div>
                </div>
                <button class="modal-close" @onclick="() => _viewMealOpen = false">✕</button>
            </div>

            @if (_viewMealEvent.MealItems?.Count > 0)
            {
                <div style="margin-bottom:1rem">
                    @foreach (var mi in _viewMealEvent.MealItems)
                    {
                        <div style="display:flex;justify-content:space-between;padding:.4rem 0;border-bottom:1px solid var(--c-border);font-size:.875rem">
                            <span>@mi.ProductName</span>
                            <span style="color:var(--c-text-muted)">@mi.Grams.ToString("F0") @(mi.MeasureType == 1 ? "шт" : "г")</span>
                        </div>
                    }
                </div>
            }
            else
            {
                <p style="font-size:.875rem;color:var(--c-text-muted);margin-bottom:1rem">Состав не указан</p>
            }

            <button class="btn btn-primary" @onclick="() => _ = MarkMealEventDoneAsync(_viewMealEvent)">
                ✓ Отметить выполненным
            </button>
        </div>
    </div>
}

@code {
    private static readonly System.Globalization.CultureInfo _ru = new("ru-RU");
    private static readonly string[] _dayHeaders = ["Пн","Вт","Ср","Чт","Пт","Сб","Вс"];

    private DateTime _month = new(DateTime.Today.Year, DateTime.Today.Month, 1);
    private DateOnly _selected = DateOnly.FromDateTime(DateTime.Today);
    private bool _loading = true, _modalOpen = false;

    private List<DateOnly> _calDays = [];
    private Dictionary<DateOnly, List<PlannedEventDto>> _eventsByDate = [];
    private List<DiaryItem> _diaryItems = [];

    private bool _viewMealOpen;
    private PlannedEventDto? _viewMealEvent;
    private PlannedEventDto? _editEvent;

    // Last known glucose for pre-bolus pause calculation in PlanModal
    private double _lastGlucose;

    // High-glucose alert (логика порогов — в GlucoseAlertDecider)
    private double? _alertGlucose;   // set when glucose > target and no recent insulin
    private double? _criticalGlucose; // set when glucose is critically high (correct now, delay meal)
    private TimeOnly? _pendingBolusTime; // set when glucose high but a planned bolus is imminent
    private double? _correctionDoneGlucose; // set when a correction was already given for this reading
    private double? _lowGlucose;          // set when glucose below target (hypoglycemia)
    private double? _criticalLowGlucose;  // set when glucose is severely low (life-threatening)

    protected override async Task OnInitializedAsync()
    {
        Toasts.OnChanged += OnToastsChanged;
        BuildCalendarDays();
        await LoadDataAsync();
    }

    // A planned event marked done from a toast must refresh the diary/event list here.
    private async void OnToastsChanged()
    {
        await LoadDataAsync();
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose() => Toasts.OnChanged -= OnToastsChanged;

    private void BuildCalendarDays()
    {
        _calDays = [];
        var dow = (int)_month.DayOfWeek;
        dow = dow == 0 ? 6 : dow - 1;
        var start = _month.AddDays(-dow);
        for (int i = 0; i < 42; i++)
            _calDays.Add(DateOnly.FromDateTime(start.AddDays(i)));
    }

    private async Task LoadDataAsync()
    {
        _loading = true;
        StateHasChanged();
        var planned = (await Db.GetAllAsync<PlannedEventDto>("planned_events")).Where(e => !e.IsDeleted).ToList();
        _eventsByDate = planned
            .GroupBy(e => DateOnly.FromDateTime(e.PlannedAtUtc.ToLocalTime()))
            .ToDictionary(g => g.Key, g => g.ToList());
        await LoadDiaryAsync();
        _loading = false;
    }

    private async Task LoadDiaryAsync()
    {
        _diaryItems = [];

        // Load all real data for the day
        var products = (await Db.GetAllAsync<ProductDto>("products"))
            .Where(p => !p.IsDeleted).ToDictionary(p => p.Id);
        var meals = (await Db.GetAllAsync<MealEntryDto>("meals"))
            .Where(m => !m.IsDeleted && m.Date == _selected).ToList();
        var glucoseAll = (await Db.GetAllAsync<GlucoseReadingDto>("glucose"))
            .Where(g => !g.IsDeleted && DateOnly.FromDateTime(g.MeasuredAtUtc.ToLocalTime()) == _selected).ToList();
        var insulinAll = (await Db.GetAllAsync<InsulinInjectionDto>("insulin"))
            .Where(i => !i.IsDeleted && DateOnly.FromDateTime(i.InjectedAtUtc.ToLocalTime()) == _selected).ToList();

        // Planned events — with result lookup
        if (_eventsByDate.TryGetValue(_selected, out var planned))
        {
            foreach (var ev in planned)
            {
                var type = (PlannedEventType)ev.EventType;
                string? resultText = null;
                double? mealProt = null, mealFat = null, mealCarbs = null;
                // Событие может остаться IsDone=true, но реальная запись-основание была удалена
                // (или потеряна при синке). Тогда не показываем «пустое готово», а считаем событие
                // невыполненным — чтобы пользователь мог ввести замер/дозу заново.
                bool effectiveDone = ev.IsDone;

                if (ev.IsDone)
                {
                    var evLocal = ev.PlannedAtUtc.ToLocalTime();
                    if (type == PlannedEventType.Meal)
                    {
                        var totals = MealTotals(ev.MealItems ?? [], products);
                        resultText = $"{totals.Kcal:F0} ккал";
                        mealProt = totals.Protein; mealFat = totals.Fat; mealCarbs = totals.Carbs;
                    }
                    else if (type == PlannedEventType.Glucose)
                    {
                        var found = glucoseAll.FirstOrDefault(g => g.LinkedEventId == ev.Id)
                            ?? glucoseAll.Where(g => Math.Abs((g.MeasuredAtUtc.ToLocalTime() - evLocal).TotalMinutes) <= 15)
                                         .OrderBy(g => Math.Abs((g.MeasuredAtUtc.ToLocalTime() - evLocal).TotalMinutes))
                                         .FirstOrDefault();
                        if (found is not null)
                            resultText = $"{found.ValueMmol:F1} ммоль/л";
                        else
                            effectiveDone = false; // замер удалён — событие снова невыполненное
                    }
                    else if (type == PlannedEventType.Insulin)
                    {
                        // Dual-wave болюс пишет две записи на одно событие — суммируем дозу,
                        // иначе в результате отобразится только немедленная часть.
                        var linked = insulinAll.Where(i => i.LinkedEventId == ev.Id).ToList();
                        var found = linked.Count > 0
                            ? linked.OrderBy(i => i.InjectedAtUtc).First()
                            : insulinAll.Where(i => Math.Abs((i.InjectedAtUtc.ToLocalTime() - evLocal).TotalMinutes) <= 15)
                                         .OrderBy(i => Math.Abs((i.InjectedAtUtc.ToLocalTime() - evLocal).TotalMinutes))
                                         .FirstOrDefault();
                        if (found is not null)
                        {
                            var totalUnits = linked.Count > 0 ? linked.Sum(i => i.Units) : found.Units;
                            var typeLabel = (GlucoTrack.Shared.Entities.InsulinType)found.InsulinType == GlucoTrack.Shared.Entities.InsulinType.Bolus ? "болюс" : "базал";
                            resultText = $"{totalUnits:F1} ЕД · {typeLabel}";
                        }
                        else
                            effectiveDone = false; // инъекция удалена — событие снова невыполненное
                    }
                    else
                    {
                        resultText = type switch
                        {
                            PlannedEventType.Activity => "выполнено",
                            PlannedEventType.Weight   => "зафиксировано",
                            _ => null
                        };
                    }
                }

                string? sub = ev.Note;
                if (type == PlannedEventType.Meal && ev.MealItems?.Count > 0)
                {
                    var mealSub = string.Join(", ", ev.MealItems.Select(m => m.ProductName));
                    sub = string.IsNullOrEmpty(sub) ? mealSub : $"{sub} · {mealSub}";
                }
                if (type == PlannedEventType.Insulin && ev.InsulinSubtype.HasValue)
                {
                    var subLabel = ev.InsulinSubtype == 0 ? "короткий (болюс)" : "длительный (базал)";
                    sub = string.IsNullOrEmpty(sub) ? subLabel : $"{subLabel} · {sub}";
                }

                _diaryItems.Add(new DiaryItem(
                    ev.PlannedAtUtc.ToLocalTime(),
                    PlannedEventMeta.Label(type), sub,
                    true, effectiveDone, ev.Id, (int)type, resultText,
                    IsInsulinBolus: type == PlannedEventType.Insulin ? (ev.InsulinSubtype ?? 0) == 0 : null,
                    Protein: mealProt, Fat: mealFat, Carbs: mealCarbs));
            }
        }

        // Реальные записи, скрытые за выполненным плановым событием — по явной ссылке (надёжно) или ±15 мин (фоллбэк).
        var diaryPlannedEvents = _eventsByDate.Values.SelectMany(v => v);
        var doneGlucoseEvents = diaryPlannedEvents.Where(e => e.IsDone && (PlannedEventType)e.EventType == PlannedEventType.Glucose);
        var doneInsulinEvents = diaryPlannedEvents.Where(e => e.IsDone && (PlannedEventType)e.EventType == PlannedEventType.Insulin);
        var doneGlucoseIds = EventReconciler.HiddenRecordIds(glucoseAll,
            g => g.Id, g => g.LinkedEventId, g => g.MeasuredAtUtc, doneGlucoseEvents);
        var doneInsulinIds = EventReconciler.HiddenRecordIds(insulinAll,
            i => i.Id, i => i.LinkedEventId, i => i.InjectedAtUtc, doneInsulinEvents);

        // Записи питания, скрытые за выполненным плановым событием (чтобы не было дубля)
        var doneMealEntryIds = EventReconciler.HiddenMealEntryIds(meals, _eventsByDate.Values.SelectMany(v => v));

        // Real meals — группируем по времени, чтобы один приём пищи = одна строка
        var mealsByTime = meals
            .Where(m => !doneMealEntryIds.Contains(m.Id))
            .GroupBy(m => m.Time)
            .OrderBy(g => g.Key);

        foreach (var group in mealsByTime)
        {
            var items = group.ToList();
            var totals = MealTotals(
                items.Select(m => new PlannedMealItem(m.ProductId, "", m.Grams,
                    products.TryGetValue(m.ProductId, out var pm) ? pm.MeasureType : 0,
                    pm?.PieceWeightG)),
                products);
            var parts = new List<string>();

            foreach (var m in items)
            {
                products.TryGetValue(m.ProductId, out var p);
                var portion = p?.MeasureType == 1 ? $"{m.Grams:F0} шт" : $"{m.Grams:F0} г";
                parts.Add($"{p?.Name ?? "Продукт"} {portion}");
            }

            string title, sub;
            if (items.Count == 1)
            {
                products.TryGetValue(items[0].ProductId, out var sp);
                title = sp?.Name ?? "Продукт";
                sub = sp?.MeasureType == 1 ? $"{items[0].Grams:F0} шт" : $"{items[0].Grams:F0} г";
            }
            else
            {
                title = "Приём пищи";
                sub = string.Join(" · ", parts);
            }

            _diaryItems.Add(new DiaryItem(
                _selected.ToDateTime(group.Key),
                title, sub, false, true, null, (int)PlannedEventType.Meal, $"{totals.Kcal:F0} ккал",
                Protein: totals.Protein, Fat: totals.Fat, Carbs: totals.Carbs));
        }

        // Real glucose (skip records already shown via done planned events)
        foreach (var g in glucoseAll.Where(g => !doneGlucoseIds.Contains(g.Id)))
            _diaryItems.Add(new DiaryItem(
                g.MeasuredAtUtc.ToLocalTime(),
                $"{g.ValueMmol:F1} ммоль/л", null,
                false, true, null, (int)PlannedEventType.Glucose, null));

        // Real insulin (skip records already shown via done planned events)
        foreach (var ins in insulinAll.Where(i => !doneInsulinIds.Contains(i.Id)))
        {
            var isBolus = (GlucoTrack.Shared.Entities.InsulinType)ins.InsulinType == GlucoTrack.Shared.Entities.InsulinType.Bolus;
            _diaryItems.Add(new DiaryItem(
                ins.InjectedAtUtc.ToLocalTime(),
                isBolus ? $"Болюс {ins.Units:F1} ЕД" : $"Базал {ins.Units:F1} ЕД",
                null, false, true, null, (int)PlannedEventType.Insulin, null,
                IsInsulinBolus: isBolus));
        }

        // High-glucose alert — решение вынесено в тестируемый GlucoseAlertDecider.
        _alertGlucose = null;
        _pendingBolusTime = null;
        _criticalGlucose = null;
        _correctionDoneGlucose = null;
        _lowGlucose = null;
        _criticalLowGlucose = null;
        if (_selected == DateOnly.FromDateTime(DateTime.Today) && glucoseAll.Count > 0)
        {
            var settings = (await Db.GetAllAsync<UserSettingsDto>("settings")).FirstOrDefault();
            double target = settings?.TargetGlucoseHigh ?? 10.0;
            double targetLow = settings?.TargetGlucoseLow > 0 ? settings.TargetGlucoseLow : GlucoseAlertDecider.DefaultTargetLowMmol;
            // MeasuredAtUtc can tie (same-minute entries) — UpdatedAtUtc (real save time) breaks
            // the tie deterministically, so the truly last-entered reading wins.
            var latest = glucoseAll.OrderByDescending(g => g.MeasuredAtUtc).ThenByDescending(g => g.UpdatedAtUtc).First();
            // Pass latest glucose to PlanModal for dynamic pre-bolus timing (only if recent ≤2h)
            if ((DateTime.UtcNow - latest.MeasuredAtUtc).TotalHours <= 2)
                _lastGlucose = latest.ValueMmol;
            var allEvents = _eventsByDate.Values.SelectMany(v => v);

            // Коэффициенты терапии для текущего времени суток — чтобы алерт умел сравнивать
            // активный инсулин (IOB) с реально нужной коррекцией, а не просто гасить алерт
            // по факту «болюс был недавно».
            var coeffs = (await Db.GetAllAsync<TherapyCoeffDto>("therapy")).Where(c => !c.IsDeleted).ToList();
            var nowTime = TimeOnly.FromDateTime(DateTime.Now);
            var coeff = coeffs.FirstOrDefault(c => c.CoversTime(nowTime)) ?? coeffs.FirstOrDefault();

            var insulinProfiles = await Db.GetAllAsync<UserInsulinDto>("user_insulins");
            var (diaHours, peakMinutes) = GlucoTrack.Shared.Calculations.InsulinProfileResolver
                .ActiveBolusCurve(insulinProfiles, settings?.DiaHours ?? 4.0);

            var alert = GlucoseAlertDecider.Decide(latest.ValueMmol, target, insulinAll, allEvents, DateTime.UtcNow,
                correctionTarget: settings?.TargetGlucose,
                insulinSensitivityFactor: coeff?.InsulinSensitivityFactor,
                diaHours: diaHours,
                latestGlucoseAtUtc: latest.MeasuredAtUtc,
                targetLow: targetLow,
                peakMinutes: peakMinutes);
            switch (alert.Kind)
            {
                case GlucoseAlertKind.CriticalLow:
                    _criticalLowGlucose = alert.Glucose;
                    break;
                case GlucoseAlertKind.Low:
                    _lowGlucose = alert.Glucose;
                    break;
                case GlucoseAlertKind.Critical:
                    _criticalGlucose = alert.Glucose;
                    break;
                case GlucoseAlertKind.PendingBolus:
                    _pendingBolusTime = TimeOnly.FromDateTime(alert.PendingBolusUtc!.Value.ToLocalTime());
                    break;
                case GlucoseAlertKind.Correction:
                    _alertGlucose = alert.Glucose;
                    break;
                case GlucoseAlertKind.CorrectionDone:
                    _correctionDoneGlucose = alert.Glucose;
                    break;
            }
        }
    }

    private bool IsActionable(DiaryItem item) =>
        item.IsPlanned && !item.IsDone &&
        item.Time <= DateTime.Now.AddMinutes(1);

    private async Task OnDiaryItemClick(DiaryItem item)
    {
        if (!IsActionable(item) || item.EventId == null) return;

        var type = (PlannedEventType)item.EventType;
        switch (type)
        {
            case PlannedEventType.Glucose:
                Nav.NavigateTo($"/glucose?eventId={item.EventId}");
                break;
            case PlannedEventType.Insulin:
                await OpenInsulinBolusAsync(item.EventId!.Value);
                break;
            case PlannedEventType.Meal:
                var mealEv = GetPlannedEvent(item.EventId!.Value);
                if (mealEv is not null) { _viewMealEvent = mealEv; _viewMealOpen = true; }
                break;
            case PlannedEventType.Activity:
                // Handled by inline button
                break;
            case PlannedEventType.Weight:
                Nav.NavigateTo("/settings");
                break;
        }
    }

    private async Task MarkDoneAsync(Guid eventId)
    {
        var events = await Db.GetAllAsync<PlannedEventDto>("planned_events");
        var ev = events.FirstOrDefault(e => e.Id == eventId);
        if (ev is not null)
            await Db.PutAsync("planned_events",
                ev with { IsDone = true, UpdatedAtUtc = DateTime.UtcNow },
                pending: true);
        // Reload full data (not just the diary): the dedup that hides a real meal entry
        // behind its done planned event relies on _eventsByDate, which is rebuilt here.
        await LoadDataAsync();
        StateHasChanged();
    }

    private async Task OpenInsulinBolusAsync(Guid insulinEventId)
    {
        // Find nearest planned meal event within 90 min after this insulin event
        var allEvents = await Db.GetAllAsync<PlannedEventDto>("planned_events");
        var insulinEv = allEvents.FirstOrDefault(e => e.Id == insulinEventId);

        // Базал не считается через калькулятор болюса (нет дозы на еду/коррекцию) и не должен
        // записываться болюсом — ведём в ручную форму журнала, которая учитывает InsulinSubtype.
        if ((insulinEv?.InsulinSubtype ?? 0) == 1)
        {
            Nav.NavigateTo($"/insulin?eventId={insulinEventId}");
            return;
        }

        var insulinTime = insulinEv?.PlannedAtUtc ?? DateTime.UtcNow;

        var mealEv = allEvents
            .Where(e => !e.IsDeleted && (PlannedEventType)e.EventType == PlannedEventType.Meal
                && e.PlannedAtUtc >= insulinTime
                && e.PlannedAtUtc <= insulinTime.AddMinutes(90))
            .OrderBy(e => e.PlannedAtUtc)
            .FirstOrDefault();

        // Calculate total carbs from meal
        double totalCarbs = 0;
        if (mealEv?.MealItems?.Count > 0)
        {
            var products = (await Db.GetAllAsync<ProductDto>("products")).ToDictionary(p => p.Id);
            foreach (var item in mealEv.MealItems)
            {
                if (products.TryGetValue(item.ProductId, out var prod))
                {
                    var grams = NutritionMath.EffectiveGrams(prod.MeasureType, item.Grams, prod.PieceWeightG);
                    totalCarbs += prod.CarbsPer100g * grams / 100.0;
                }
            }
        }

        // Get latest glucose (within 2 hours)
        var glucose = (await Db.GetAllAsync<GlucoseReadingDto>("glucose"))
            .Where(g => !g.IsDeleted && (DateTime.UtcNow - g.MeasuredAtUtc).TotalHours <= 2)
            .OrderByDescending(g => g.MeasuredAtUtc)
            .FirstOrDefault();

        var url = $"/bolus?eventId={insulinEventId}";
        if (totalCarbs > 0)
            url += $"&carbs={totalCarbs.ToString("F0", System.Globalization.CultureInfo.InvariantCulture)}";
        if (glucose is not null)
            url += $"&glucose={glucose.ValueMmol.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)}";
        Nav.NavigateTo(url);
    }

    private void SelectDay(DateOnly day)
    {
        _selected = day;
        if (day.Month != _month.Month)
            _month = new DateTime(day.Year, day.Month, 1);
        _ = LoadDiaryAsync().ContinueWith(_ => InvokeAsync(StateHasChanged));
    }

    private static string EventDotClass(PlannedEventType type) => type switch
    {
        PlannedEventType.Meal     => "meal",
        PlannedEventType.Glucose  => "glucose",
        PlannedEventType.Insulin  => "insulin",
        PlannedEventType.Weight   => "weight",
        PlannedEventType.Activity => "activity",
        _ => "meal"
    };

    private void PrevMonth() { _month = _month.AddMonths(-1); BuildCalendarDays(); }
    private void NextMonth() { _month = _month.AddMonths(1); BuildCalendarDays(); }

    private PlannedEventDto? GetPlannedEvent(Guid eventId) =>
        _eventsByDate.Values.SelectMany(v => v).FirstOrDefault(e => e.Id == eventId);

    private async Task MarkMealEventDoneAsync(PlannedEventDto ev)
    {
        _viewMealOpen = false;
        if (ev.MealItems?.Count > 0)
        {
            foreach (var mi in ev.MealItems)
            {
                var dto = new MealEntryDto(
                    Guid.NewGuid(),
                    DateOnly.FromDateTime(ev.PlannedAtUtc.ToLocalTime()),
                    TimeOnly.FromDateTime(ev.PlannedAtUtc.ToLocalTime()),
                    (int)GlucoTrack.Shared.Entities.MealType.Snack,
                    mi.ProductId, mi.Grams,
                    DateTime.UtcNow, false,
                    LinkedEventId: ev.Id);
                await Db.PutAsync("meals", dto, pending: true);
            }
            _ = Sync.SyncAsync();
        }
        await MarkDoneAsync(ev.Id);
    }

    private void OpenModal() { _editEvent = null; _modalOpen = true; }
    private void CloseModal() { _editEvent = null; _modalOpen = false; }
    private async Task OnEventSaved() { _editEvent = null; _modalOpen = false; await LoadDataAsync(); }

    private void GoToInsulinAlert(double glucose) =>
        Nav.NavigateTo($"/insulin?alert=1&glucose={glucose.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)}");

    private void OpenEditModal(Guid eventId)
    {
        _editEvent = GetPlannedEvent(eventId);
        if (_editEvent is not null) _modalOpen = true;
    }

    private record DiaryItem(
        DateTime Time, string Title, string? Sub,
        bool IsPlanned, bool IsDone,
        Guid? EventId, int EventType, string? ResultText,
        bool? IsInsulinBolus = null,
        double? Protein = null, double? Fat = null, double? Carbs = null);

    private static (double Kcal, double Protein, double Fat, double Carbs) MealTotals(
        IEnumerable<PlannedMealItem> items, Dictionary<Guid, ProductDto> products)
    {
        double kcal = 0, prot = 0, fat = 0, carbs = 0;
        foreach (var m in items)
        {
            if (!products.TryGetValue(m.ProductId, out var p)) continue;
            var k = NutritionMath.EffectiveGrams(m.MeasureType, m.Grams, m.PieceWeightG) / 100.0;
            kcal += p.CaloriesPer100g * k; prot += p.ProteinPer100g * k;
            fat  += p.FatPer100g * k;      carbs += p.CarbsPer100g * k;
        }
        return (kcal, prot, fat, carbs);
    }

    private static string DiaryIconPath(PlannedEventType t) => t switch
    {
        PlannedEventType.Meal     => "icons/meals.svg",
        PlannedEventType.Glucose  => "icons/glucometer.svg",
        PlannedEventType.Insulin  => "icons/insulin.svg",
        PlannedEventType.Weight   => "icons/weighing.svg",
        PlannedEventType.Activity => "icons/training.svg",
        _ => "icons/meals.svg"
    };

    private static string DiaryIconColorClass(DiaryItem item) => (PlannedEventType)item.EventType switch
    {
        PlannedEventType.Meal     => "diary-icon-meal",
        PlannedEventType.Glucose  => "diary-icon-glucose",
        PlannedEventType.Insulin  => item.IsInsulinBolus == false ? "diary-icon-insulin-basal" : "diary-icon-insulin-bolus",
        PlannedEventType.Weight   => "diary-icon-weight",
        PlannedEventType.Activity => "diary-icon-activity",
        _ => "diary-icon-meal"
    };

    private static string DiaryIconBgClass(DiaryItem item) => "diary-icon-bg-" + DiaryIconColorClass(item)["diary-icon-".Length..];
    private static string DiaryCardBgClass(DiaryItem item) => "diary-card-bg-" + DiaryIconColorClass(item)["diary-icon-".Length..];
