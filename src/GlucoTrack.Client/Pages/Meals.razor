@page "/meals"
@attribute [Authorize]
@using GlucoTrack.Shared.DTOs.Sync
@using GlucoTrack.Shared.Entities
@using GlucoTrack.Shared.Calculations
@using GlucoTrack.Shared.Events
@using GlucoTrack.Client.Models
@inject DbService Db
@inject SyncService Sync
@inject ConfirmService Confirm
@inject UndoService Undo
@inject NavigationManager Nav
@inject ModuleService Modules
@implements IDisposable

<PageTitle>Питание — GlucoTrack</PageTitle>

<div class="page">
    <div class="page-header">
        <h2>🥗 Дневник питания</h2>
        <button class="btn btn-primary btn-sm" @onclick="() => _showAddMeal = !_showAddMeal">
            @(_showAddMeal ? "Отмена" : "+ Добавить приём")
        </button>
    </div>

    <!-- Uncovered carbs banner -->
    @if (_uncoveredCarbs > 0.5)
    {
        <div style="background:#FEF3C7;border:1.5px solid #F59E0B;border-radius:var(--r-md);padding:.65rem 1rem;font-size:.85rem;color:#92400E;margin-bottom:1rem;display:flex;align-items:center;justify-content:space-between;gap:.75rem">
            <span>⚠️ Вы съели <strong>+@_uncoveredCarbs.ToString("F0") г углеводов</strong> сверх рассчитанного болюса — они не покрыты инсулином.</span>
            <a href="/bolus?carbs=@_uncoveredCarbs.ToString("F0", System.Globalization.CultureInfo.InvariantCulture)" style="white-space:nowrap;font-weight:600;color:#92400E;text-decoration:underline">Рассчитать доп. дозу →</a>
        </div>
    }

    <!-- Date navigation -->
    <div class="date-nav">
        <button @onclick="PrevDay">◀</button>
        <span class="date-display">@_date.ToString("dd MMMM", new System.Globalization.CultureInfo("ru-RU"))</span>
        <button @onclick="NextDay">▶</button>
        <button class="btn btn-ghost btn-sm" @onclick="GoToday">Сегодня</button>
    </div>

    <!-- Daily summary -->
    @if (_dayEntries.Count > 0)
    {
        <div class="stats-bar" style="margin-bottom:1.5rem">
            <div class="stat-card">
                <div class="stat-value">@_dayCal.ToString("F0")</div>
                <div class="stat-label">ккал</div>
            </div>
            <div class="stat-card">
                <div class="stat-value">@_dayProt.ToString("F1")</div>
                <div class="stat-label">Белки, г</div>
            </div>
            <div class="stat-card">
                <div class="stat-value">@_dayFat.ToString("F1")</div>
                <div class="stat-label">Жиры, г</div>
            </div>
            <div class="stat-card">
                <div class="stat-value">@_dayCarbs.ToString("F1")</div>
                <div class="stat-label">Углеводы, г</div>
            </div>
            <div class="stat-card">
                <div class="stat-value">@XeCalculator.CarbsToXe(_dayCarbs, _xeGrams).ToString("F1")</div>
                <div class="stat-label">ХЕ</div>
            </div>
        </div>
    }

    <!-- Add meal form -->
    @if (_showAddMeal)
    {
        <div class="form-card" style="margin-bottom:1.5rem">
            <h4>Новый приём пищи</h4>
            <div class="input-row" style="margin-bottom:.75rem">
                <div class="form-group">
                    <label>Время</label>
                    <input class="form-control" type="time" value="@_newTime" @oninput="e => _newTime = e.Value?.ToString() ?? _newTime" />
                </div>
                <div class="form-group" style="justify-content:flex-end;display:flex;align-items:center;gap:.5rem;padding-top:1.5rem">
                    <input type="checkbox" id="snack-cb" @bind="_isSnack" style="width:1.1rem;height:1.1rem;cursor:pointer" />
                    <label for="snack-cb" style="margin:0;cursor:pointer;user-select:none">🍎 Перекус</label>
                </div>
            </div>

            <!-- Product search -->
            <div class="form-group">
                <label>Продукт</label>
                <div style="display:flex;gap:.5rem">
                    <input class="form-control" type="text" placeholder="Поиск по названию..."
                           style="flex:1"
                           @bind="_productSearch" @oninput="SearchProducts" />
                    <button class="btn btn-ghost btn-sm" style="flex-shrink:0" @onclick="() => _showCatalog = true"><img src="icons/catalog.svg" width="32" height="32" /> Каталог</button>
                </div>
                @if (_searchResults.Count > 0 && _selectedProduct is null)
                {
                    <div class="search-results">
                        @foreach (var p in _searchResults)
                        {
                            <ProductSearchResultItem Product="p" OnClick="SelectProduct" />
                        }
                    </div>
                }
                @if (_selectedProduct is not null)
                {
                    <div style="margin-top:.5rem;padding:.5rem .75rem;background:var(--bg);border-radius:8px;font-size:.875rem;display:flex;justify-content:space-between;align-items:center">
                        <span>✓ @_selectedProduct.Name</span>
                        <a style="cursor:pointer;color:var(--text-muted)" @onclick="ClearProduct">✕</a>
                    </div>
                }
            </div>

            @if (_selectedProduct is null && _productSearch.Length > 2)
            {
                <details style="margin-bottom:.75rem">
                    <summary style="cursor:pointer;font-size:.875rem;color:var(--primary)">+ Добавить новый продукт</summary>
                    <div style="margin-top:.75rem">
                        <div class="input-row" style="margin-bottom:.5rem">
                            <div class="form-group">
                                <label>Калории (на 100г)</label>
                                <input class="form-control" type="number" @bind="_npCal" />
                            </div>
                            <div class="form-group">
                                <label>Белки (г/100г)</label>
                                <input class="form-control" type="number" step="0.1" @bind="_npProt" />
                            </div>
                        </div>
                        <div class="input-row" style="margin-bottom:.5rem">
                            <div class="form-group">
                                <label>Жиры (г/100г)</label>
                                <input class="form-control" type="number" step="0.1" @bind="_npFat" />
                            </div>
                            <div class="form-group">
                                <label>Углеводы (г/100г)</label>
                                <input class="form-control" type="number" step="0.1" @bind="_npCarbs" />
                            </div>
                        </div>
                        <button class="btn btn-ghost btn-sm" @onclick="CreateAndSelectProductAsync">Создать «@_productSearch»</button>
                    </div>
                </details>
            }

            <div class="form-group" style="max-width:150px">
                <label>@(_selectedProduct?.MeasureType == 1 ? "Количество (шт)" : "Масса (г)")</label>
                <input class="form-control" type="number" min="1" step="1" @bind="_newGrams" />
            </div>

            @if (_selectedProduct is not null)
            {
                var isByPiece = _selectedProduct.MeasureType == 1;
                var previewG = NutritionMath.EffectiveGrams(_selectedProduct.MeasureType, _newGrams, _selectedProduct.PieceWeightG);
                var k = previewG / 100.0;
                <div style="font-size:.82rem;color:var(--text-muted);margin-bottom:.75rem">
                    Калории: <b>@((_selectedProduct.CaloriesPer100g * k).ToString("F0"))</b> ккал ·
                    Б: <b>@((_selectedProduct.ProteinPer100g * k).ToString("F1"))</b> ·
                    Ж: <b>@((_selectedProduct.FatPer100g * k).ToString("F1"))</b> ·
                    У: <b>@((_selectedProduct.CarbsPer100g * k).ToString("F1"))</b> г
                </div>
            }

            @if (_mealErr is not null) { <div class="alert alert-error">@_mealErr</div> }
            <button class="btn btn-primary btn-sm" @onclick="AddMealAsync" disabled="@(_selectedProduct is null)">Добавить</button>
        </div>
    }

    <!-- Meals grouped by type -->
    @if (_dayEntries.Count > 0)
    {
        @foreach (var group in _dayEntries.GroupBy(e => (MealType)e.MealType).OrderBy(g => (int)g.Key))
        {
            <div class="meal-group">
                <div class="meal-group-title">
                    <img src="@MealTypeIcon(group.Key)" style="width:1.2rem;height:1.2rem;vertical-align:middle;margin-right:.35rem" />
                    @MealTypeName(group.Key)
                </div>
                <div class="entry-list">
                    @foreach (var entry in group.OrderBy(e => e.Time))
                    {
                        var p = _productsMap.GetValueOrDefault(entry.ProductId);
                        var byPiece = p?.MeasureType == 1;
                        var effG = p is null ? entry.Grams : NutritionMath.EffectiveGrams(p.MeasureType, entry.Grams, p.PieceWeightG);
                        var k = effG / 100.0;
                        var portionLabel = byPiece ? $"{entry.Grams:F0} шт" : $"{entry.Grams:F0} г";
                        <div class="entry-item">
                            <div class="entry-time">@entry.Time.ToString("HH:mm")</div>
                            <div class="entry-main">
                                <div class="entry-value">@(p?.Name ?? "—")</div>
                                <div class="entry-sub">
                                    @portionLabel ·
                                    @(p is not null ? $"{p.CaloriesPer100g * k:F0} ккал · Б {p.ProteinPer100g * k:F1} · Ж {p.FatPer100g * k:F1} · У {p.CarbsPer100g * k:F1} г" : "")
                                </div>
                            </div>
                            <button class="btn btn-ghost btn-sm btn-icon" @onclick="() => DeleteMealAsync(entry.Id)">✕</button>
                        </div>
                    }
                </div>
            </div>
        }
    }
    else if (!_loading)
    {
        <div class="placeholder-page" style="min-height:35vh">
            <div class="placeholder-icon">🥗</div>
            <h2>Нет записей</h2>
            <p>Добавьте первый приём пищи</p>
        </div>
    }
</div>

@if (_showCatalog)
{
    <ProductCatalogModal Products="_products"
                          OnSelect="SelectProduct"
                          OnClose="() => _showCatalog = false" />
}

@code {
    private DateOnly _date = DateOnly.FromDateTime(DateTime.Today);
    private List<MealEntryDto> _allEntries = [], _dayEntries = [];
    private List<ProductDto> _products = [];
    private Dictionary<Guid, ProductDto> _productsMap = [];
    private bool _loading = true, _showAddMeal, _showCatalog;
    private string? _mealErr;

    // Add form
    private bool _isSnack;
    private string _newTime = DateTime.Now.ToString("HH:mm");
    private double _newGrams = 100;
    private string _productSearch = "";
    private List<ProductDto> _searchResults = [];
    private ProductDto? _selectedProduct;

    // New product form
    private double _npCal, _npProt, _npFat, _npCarbs;

    // Daily totals
    private double _dayCal, _dayProt, _dayFat, _dayCarbs;
    private double _xeGrams = 12;

    // Uncovered carbs detection
    private double _uncoveredCarbs;
    private List<InsulinInjectionDto> _injections = [];

    protected override async Task OnInitializedAsync()
    {
        Nav.LocationChanged += OnLocationChanged;
        await LoadDataAsync();
    }

    private async void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        if (e.Location.Contains("/meals"))
        {
            await LoadDataAsync();
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task LoadDataAsync()
    {
        var settings = (await Db.GetAllAsync<GlucoTrack.Shared.DTOs.Sync.UserSettingsDto>("settings")).FirstOrDefault();
        if (settings is not null) _xeGrams = settings.XeGrams;
        _allEntries = (await Db.GetAllAsync<MealEntryDto>("meals")).Where(m => !m.IsDeleted).ToList();
        _products = (await Db.GetAllAsync<ProductDto>("products")).Where(p => !p.IsDeleted).ToList();
        _productsMap = _products.ToDictionary(p => p.Id);
        _injections = (await Db.GetAllAsync<InsulinInjectionDto>("insulin")).Where(i => !i.IsDeleted).ToList();
        FilterDay(); _loading = false;
    }

    public void Dispose() => Nav.LocationChanged -= OnLocationChanged;

    private void FilterDay()
    {
        _dayEntries = _allEntries.Where(e => e.Date == _date).ToList();
        _dayCal = _dayProt = _dayFat = _dayCarbs = 0;
        foreach (var e in _dayEntries)
        {
            if (!_productsMap.TryGetValue(e.ProductId, out var p)) continue;
            var effG = NutritionMath.EffectiveGrams(p.MeasureType, e.Grams, p.PieceWeightG);
            var k = effG / 100.0;
            _dayCal += p.CaloriesPer100g * k; _dayProt += p.ProteinPer100g * k;
            _dayFat += p.FatPer100g * k; _dayCarbs += p.CarbsPer100g * k;
        }
        CheckUncoveredCarbs();
    }

    // Show banner only when viewing today and there's a recent meal bolus (last 60 min).
    // Compare sum of Carbs field on those boluses vs actual carbs eaten in the same window.
    private void CheckUncoveredCarbs()
    {
        _uncoveredCarbs = 0;
        if (_date != DateOnly.FromDateTime(DateTime.Today)) return;

        var now = DateTime.UtcNow;
        var windowStart = now.AddMinutes(-60);

        // All meal boluses injected in the last 60 minutes
        var recentBoluses = _injections
            .Where(i => i.InsulinType == (int)GlucoTrack.Shared.Entities.InsulinType.Bolus
                        && i.Carbs is > 0
                        && i.InjectedAtUtc >= windowStart)
            .ToList();

        if (recentBoluses.Count == 0) return;

        double bolusedCarbs = recentBoluses.Sum(i => i.Carbs ?? 0);

        // Actual carbs eaten within the same window (local time comparison)
        var windowStartLocal = DateTime.Now.AddMinutes(-60);
        var windowStartTime = TimeOnly.FromDateTime(windowStartLocal);

        double eatenCarbs = _dayEntries.Sum(e =>
        {
            if (e.Time < windowStartTime) return 0.0;
            if (!_productsMap.TryGetValue(e.ProductId, out var p)) return 0.0;
            var effG = NutritionMath.EffectiveGrams(p.MeasureType, e.Grams, p.PieceWeightG);
            return p.CarbsPer100g * effG / 100.0;
        });

        var delta = eatenCarbs - bolusedCarbs;
        if (delta > 3.0) _uncoveredCarbs = delta;
    }

    private void PrevDay() { _date = _date.AddDays(-1); FilterDay(); }
    private void NextDay() { _date = _date.AddDays(1); FilterDay(); }
    private void GoToday() { _date = DateOnly.FromDateTime(DateTime.Today); FilterDay(); }

    private void SearchProducts(ChangeEventArgs e)
    {
        _productSearch = e.Value?.ToString() ?? "";
        _selectedProduct = null;
        if (_productSearch.Length < 2) { _searchResults = []; return; }
        _searchResults = _products
            .Where(p => p.Name.Contains(_productSearch, StringComparison.OrdinalIgnoreCase))
            .Take(10).ToList();
    }

    private void SelectProduct(ProductDto p)
    {
        _selectedProduct = p; _productSearch = p.Name; _searchResults = [];
        _newGrams = p.MeasureType == 1 ? 1 : 100;
    }

    private void ClearProduct() { _selectedProduct = null; _productSearch = ""; _searchResults = []; }

    private async Task CreateAndSelectProductAsync()
    {
        var dto = new ProductDto(
            Guid.NewGuid(), null, _productSearch,
            0, 1, 0, null, 100, false, null, false, null, 0, 0,
            null,
            _npCal, _npProt, _npFat, _npCarbs, 0,
            null, null, null, null, null, null, null, null, null, null, null, null, null, null,
            null, null, null, null, null, null, null, null, null, null, null,
            null, null, null, null,
            null, DateTime.UtcNow, false);
        await Db.PutAsync("products", dto, pending: true);
        _products.Add(dto); _productsMap[dto.Id] = dto;
        SelectProduct(dto);
        _ = Sync.SyncAsync();
    }

    private async Task AddMealAsync()
    {
        _mealErr = null;
        if (_selectedProduct is null) { _mealErr = "Выберите продукт"; return; }
        if (_newGrams <= 0) { _mealErr = "Масса должна быть больше 0"; return; }
        if (!TimeOnly.TryParse(_newTime, out var time)) { _mealErr = "Неверное время"; return; }

        var mealType = _isSnack ? MealType.Snack : MealTypeFromTime(time);
        var dto = new MealEntryDto(Guid.NewGuid(), _date, time, (int)mealType,
            _selectedProduct.Id, _newGrams, DateTime.UtcNow, false);
        await Db.PutAsync("meals", dto, pending: true);
        _allEntries.Add(dto);
        // Reload injections so the banner sees boluses entered after the page loaded
        _injections = (await Db.GetAllAsync<InsulinInjectionDto>("insulin")).Where(i => !i.IsDeleted).ToList();
        FilterDay();
        _showAddMeal = false; ClearProduct(); _newGrams = 100; _isSnack = false;
        _ = Sync.SyncAsync();

        // Auto-schedule post-meal glucose check in 2 hours (GlucoseModule only)
        if (Modules.GlucoseModule)
            await SchedulePostMealGlucoseCheckAsync(dto);
    }

    private async Task DeleteMealAsync(Guid id)
    {
        var item = _allEntries.First(e => e.Id == id);
        var prod = _productsMap.GetValueOrDefault(item.ProductId);
        var byPiece = prod?.MeasureType == 1;
        var label = byPiece ? $"{prod?.Name ?? "Продукт"} {item.Grams:F0} шт" : $"{prod?.Name ?? "Продукт"} {item.Grams:F0} г";
        if (!await Confirm.ConfirmAsync("Удалить запись?", label)) return;

        await Db.PutAsync("meals", item with { IsDeleted = true, UpdatedAtUtc = DateTime.UtcNow }, pending: true);
        _allEntries.RemoveAll(e => e.Id == id); FilterDay();

        // Cascade: if this meal came from a planned event, remove that event too so it
        // doesn't linger as a duplicate in the calendar diary.
        PlannedEventDto? linkedEvent = null;
        if (item.LinkedEventId is { } evId)
        {
            linkedEvent = (await Db.GetAllAsync<PlannedEventDto>("planned_events"))
                .FirstOrDefault(e => e.Id == evId && !e.IsDeleted);
            if (linkedEvent is not null)
                await Db.PutAsync("planned_events",
                    linkedEvent with { IsDeleted = true, UpdatedAtUtc = DateTime.UtcNow }, pending: false);
        }
        _ = Sync.SyncAsync();

        Undo.Push($"Удалено: {label}", async () =>
        {
            await Db.PutAsync("meals", item with { UpdatedAtUtc = DateTime.UtcNow }, pending: true);
            if (linkedEvent is not null)
                await Db.PutAsync("planned_events",
                    linkedEvent with { UpdatedAtUtc = DateTime.UtcNow }, pending: false);
            _allEntries.Add(item); FilterDay();
            _ = Sync.SyncAsync();
            await InvokeAsync(StateHasChanged);
        });
    }

    private async Task SchedulePostMealGlucoseCheckAsync(MealEntryDto meal)
    {
        // Meal time in UTC
        var mealUtc = _date.ToDateTime(meal.Time, DateTimeKind.Local).ToUniversalTime();
        var checkUtc = mealUtc.AddHours(2);

        // Skip if check time is already in the past
        if (checkUtc <= DateTime.UtcNow) return;

        // Deduplicate: don't create if there's already a glucose reminder within 30 min of target
        var existing = await Db.GetAllAsync<PlannedEventDto>("planned_events");
        var window = TimeSpan.FromMinutes(30);
        bool alreadyScheduled = existing.Any(e =>
            !e.IsDeleted &&
            e.EventType == (int)PlannedEventType.Glucose &&
            Math.Abs((e.PlannedAtUtc - checkUtc).TotalMinutes) < window.TotalMinutes);
        if (alreadyScheduled) return;

        var reminder = new PlannedEventDto(
            Guid.NewGuid(), checkUtc, (int)PlannedEventType.Glucose,
            "Измерьте сахар после еды", null, null, false, DateTime.UtcNow, false);
        await Db.PutAsync("planned_events", reminder, pending: false);
    }

    private static MealType MealTypeFromTime(TimeOnly t) => t.Hour switch
    {
        >= 5 and <= 10 => MealType.Breakfast,
        >= 11 and <= 15 => MealType.Lunch,
        >= 16 and <= 21 => MealType.Dinner,
        _ => MealType.Snack
    };

    private static string MealTypeIcon(MealType t) => t switch
    {
        MealType.Breakfast => "icons/breakfast.svg",
        MealType.Lunch     => "icons/lunch.svg",
        MealType.Dinner    => "icons/dinner.svg",
        _                  => "icons/snack.svg"
    };

    private static string MealTypeName(MealType t) => t switch
    {
        MealType.Breakfast => "Завтрак",
        MealType.Lunch     => "Обед",
        MealType.Dinner    => "Ужин",
        _                  => "Перекус"
    };

    private static string MealTypeLabel(MealType t) => t switch
    {
        MealType.Breakfast => "🌅 Завтрак",
        MealType.Lunch => "☀️ Обед",
        MealType.Dinner => "🌙 Ужин",
        _ => "🍎 Перекус"
    };
}
