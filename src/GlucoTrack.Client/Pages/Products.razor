@page "/products"
@attribute [Authorize]
@using GlucoTrack.Shared.DTOs.Sync
@using System.Text.Json
@inject DbService Db
@inject SyncService Sync
@inject HttpClient Http
@inject IJSRuntime JS
@inject ConnectivityService Connectivity

<PageTitle>Продукты — GlucoTrack</PageTitle>

<div class="products-page">

    @if (_catDropdownOpen || _openActionMenu.HasValue)
    {
        <div style="position:fixed;inset:0;z-index:498" @onclick="CloseAllDropdowns"></div>
    }

    <!-- ── Header ──────────────────────────────────────────────────── -->
    <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:1.25rem;gap:1rem">
        <div>
            <h2 style="margin:0;font-size:1.35rem;font-weight:700;color:var(--c-text)">Продукты</h2>
            <p style="margin:.15rem 0 0;font-size:.85rem;color:var(--c-text-muted)">Ваша база продуктов питания</p>
        </div>
        <div style="display:flex;gap:.5rem;align-items:center;flex-shrink:0">
            @if (_viewMode == 1)
            {
                <button class="btn btn-primary" @onclick="OpenTemplateCreate">+ Новый шаблон</button>
            }
            else if (_viewMode == 0)
            {
                <button class="btn btn-primary" @onclick="OpenAdd">+ Добавить продукт</button>
            }
        </div>
    </div>

    <!-- ── View mode switch ──────────────────────────────────────────── -->
    <div class="filter-bar-glass" style="display:flex;flex-wrap:wrap;gap:.5rem;padding:.5rem;margin-bottom:.875rem;width:fit-content">
        <button class="filter-button @(_viewMode != 1 ? "active" : "")" @onclick="() => SwitchViewMode(0)">Продукты</button>
        <button class="filter-button @(_viewMode == 1 ? "active" : "")" @onclick="() => SwitchViewMode(1)">Шаблоны меню</button>
    </div>

    <!-- ── Search ──────────────────────────────────────────────────── -->
    <div style="margin-bottom:.875rem">
        <input class="form-control products-search" type="search"
               placeholder="@(_viewMode == 1 ? "Поиск по названию меню..." : "Поиск по названию продукта...")"
               @bind="_search"
               @oninput="OnSearchInput" />
    </div>

    @if (_viewMode != 1)
    {
        <!-- ── Filter bar (источники продуктов) ──────────────────────────── -->
        <div class="filter-bar-glass" style="display:flex;flex-wrap:wrap;gap:.5rem;align-items:center;padding:.5rem;margin-bottom:1rem">
            <button class="filter-button @(_viewMode == 0 && _filter == 3 ? "active" : string.Empty)" @onclick="() => SetFilter(3)">Мои</button>
            <button class="filter-button @(_viewMode == 0 && _filter == 1 ? "active" : string.Empty)" @onclick="() => SetFilter(1)">Избранные</button>
            <button class="filter-button @(_viewMode == 0 && _filter == 2 ? "active" : string.Empty)" @onclick="() => SetFilter(2)">Часто используемые</button>
            <div style="position:relative">
                <button class="filter-button @(_viewMode == 0 && _filter == 4 ? "active" : string.Empty)" @onclick="ToggleCatDropdown">
                    @(_catFilter.HasValue ? $"Категория: {CategoryLabel(_catFilter.Value)}" : "Категории") ▾
                </button>
                @if (_catDropdownOpen)
                {
                    <div class="action-dropdown" style="min-width:190px;top:calc(100% + 4px);left:0" @onclick:stopPropagation>
                        <button @onclick="() => SelectCategory(null)">Все категории</button>
                        @foreach (var (val, lbl) in _categories)
                        {
                            var v = val;
                            <button @onclick="() => SelectCategory(v)">
                                <span style="display:flex;align-items:center;gap:.5rem">
                                    <img src="icons/@(CategoryIconName(v)).svg" width="20" height="20" />@lbl
                                </span>
                            </button>
                        }
                    </div>
                }
            </div>
            <span style="width:1px;height:1.5rem;background:var(--c-border);margin:0 .25rem"></span>
            <button class="filter-button @(_viewMode == 4 ? "active" : "")" @onclick="() => SwitchViewMode(4)">Базовые</button>
            <button class="filter-button @(_viewMode == 2 ? "active" : "")" @onclick="() => SwitchViewMode(2)">От сообщества</button>
            <button class="filter-button @(_viewMode == 3 ? "active" : "")" @onclick="() => SwitchViewMode(3)">Скрытые</button>
        </div>
    }

    @if (_viewMode == 1)
    {
        <!-- ═══ Шаблоны меню ═══════════════════════════════════════════ -->
        @if (_tplApplied is not null)
        {
            <div style="margin-bottom:.75rem;background:#DCFCE7;border:1.5px solid #86EFAC;border-radius:var(--r-md);padding:.6rem .875rem;font-size:.875rem;color:#166534">
                ✓ Шаблон «@_tplApplied» добавлен в питание сегодня
            </div>
        }
        @if (_templatesLoading)
        {
            <p style="color:var(--c-text-muted);padding:2rem 0">Загрузка...</p>
        }
        else
        {
            var tplList = _templates.Where(t => !t.IsDeleted
                && (string.IsNullOrEmpty(_search) || t.Name.Contains(_search, StringComparison.OrdinalIgnoreCase)))
                .OrderBy(t => t.Name).ToList();

            @if (tplList.Count == 0)
            {
                <div class="home-card" style="text-align:center;padding:2.5rem;color:var(--c-text-muted)">
                    <img src="icons/templates.svg" style="width:7.5rem;height:7.5rem" />
                    <div style="margin-top:.5rem;font-size:.9rem">
                        @if (string.IsNullOrEmpty(_search))
                        { <span>Нет шаблонов. Создайте первый набор продуктов для быстрого добавления.</span> }
                        else { <span>Ничего не найдено по запросу «@_search»</span> }
                    </div>
                </div>
            }
            else
            {
                <div class="products-table-wrapper" style="background:#fff;border-radius:12px;border:1px solid var(--c-border);overflow:hidden;box-shadow:var(--s-xs);margin-bottom:1rem">
                    <table class="products-table" style="width:100%;border-collapse:collapse;font-size:.9rem">
                        <thead>
                            <tr>
                                <th style="width:22px"></th>
                                <th style="width:52px"></th>
                                <th>Название</th>
                                <th>Калории <span class="col-unit">(на 100 г)</span></th>
                                <th>БЖУ <span class="col-unit">(на 100 г)</span></th>
                                <th style="width:88px">Действие</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var tpl in tplList)
                            {
                                var tplKcal = TplKcal(tpl);
                                var tplProt = TplNutrient(tpl, p => p.ProteinPer100g);
                                var tplFat = TplNutrient(tpl, p => p.FatPer100g);
                                var tplCarbs = TplNutrient(tpl, p => p.CarbsPer100g);
                                var expanded = _expandedTplId == tpl.Id;
                                <tr @key="tpl.Id" class="product-row-clickable" @onclick="() => ToggleTplExpand(tpl.Id)">
                                    <td>
                                        <span style="font-size:.72rem;color:var(--c-text-muted)">@(expanded ? "▾" : "▸")</span>
                                    </td>
                                    <td>
                                        <div class="product-icon-cell">
                                            @if (tpl.HasImage)
                                            {
                                                <img src="@TplImageUrl(tpl)" alt="" class="product-row-img"
                                                     onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
                                            }
                                            <div class="product-cat-icon" style="display:@(tpl.HasImage ? "none" : "flex")">
                                                <img src="icons/templates.svg" width="28" height="28" />
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="product-name-cell">
                                            <span class="product-row-name">@tpl.Name</span>
                                            <span class="product-row-mfr">@tpl.Items.Count поз.</span>
                                        </div>
                                    </td>
                                    <td class="product-row-num">@tplKcal.ToString("F0") ккал</td>
                                    <td>
                                        <div style="display:flex;flex-direction:column;gap:0;line-height:1.15;font-size:.78rem;font-variant-numeric:tabular-nums;white-space:nowrap">
                                            <span><span style="display:inline-block;width:.9rem;color:var(--c-protein);font-size:.68rem;font-weight:600">Б</span>@tplProt.ToString("F1")</span>
                                            <span><span style="display:inline-block;width:.9rem;color:var(--c-fat);font-size:.68rem;font-weight:600">Ж</span>@tplFat.ToString("F1")</span>
                                            <span><span style="display:inline-block;width:.9rem;color:var(--c-carbs);font-size:.68rem;font-weight:600">У</span>@tplCarbs.ToString("F1")</span>
                                        </div>
                                    </td>
                                    <td @onclick:stopPropagation>
                                        <div class="product-row-actions">
                                            <button class="btn btn-ghost btn-icon btn-sm" @onclick="() => OpenTemplateEdit(tpl)">
                                                <img src="icons/edit.svg" width="18" height="18" />
                                            </button>
                                            <button class="btn btn-ghost btn-icon btn-sm" @onclick="() => TplDeleteAsync(tpl)">
                                                <img src="icons/deleted.svg" width="18" height="18" />
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                                @if (expanded)
                                {
                                    <tr @key="@($"{tpl.Id}-exp")" class="product-row-expanded">
                                        <td colspan="6">
                                            <div style="display:flex;flex-direction:column;gap:.4rem;padding:.4rem .5rem">
                                                @foreach (var item in tpl.Items)
                                                {
                                                    var ip = _allProducts.FirstOrDefault(x => x.Id == item.ProductId);
                                                    var ik = ip is null ? 0 : NutritionMath(ip, item.Grams);
                                                    <div style="display:flex;align-items:center;gap:.6rem;background:#fff;border-radius:8px;padding:.4rem .6rem">
                                                        <div class="product-icon-cell" style="flex-shrink:0">
                                                            @if (ip is { HasImage: true })
                                                            {
                                                                <img src="@ProductImageUrl(ip)" alt="" class="product-row-img"
                                                                     onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
                                                            }
                                                            <div class="product-cat-icon" style="display:@(ip is { HasImage: true } ? "none" : "flex")">
                                                                <img src="icons/@(CategoryIconName(ip?.Category ?? 0)).svg" />
                                                            </div>
                                                        </div>
                                                        <div style="flex:1;min-width:0;font-size:.85rem">@item.ProductName</div>
                                                        <div style="font-size:.78rem;color:var(--c-text-muted);white-space:nowrap">
                                                            @(item.MeasureType == 1 ? $"{item.Grams:F0} шт" : $"{item.Grams:F0} г")
                                                            @if (ip is not null)
                                                            { <span> · @((ip.CaloriesPer100g * ik).ToString("F0")) ккал</span> }
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            }
        }
    }

    @if (_viewMode == 2 || _viewMode == 4)
    {
        <!-- ═══ От сообщества / Базовые (живой запрос к серверу) ═══════════ -->
        @if (!Connectivity.IsOnline)
        {
            <div class="home-card" style="text-align:center;padding:2.5rem;color:var(--c-text-muted)">
                <img src="icons/incloud.svg" style="width:5rem;height:5rem;opacity:.45" />
                <div style="margin-top:.75rem;font-size:.9rem">Нет соединения с интернетом.</div>
                <div style="font-size:.82rem">Этот раздел требует доступа к серверу — подключитесь к интернету и попробуйте снова.</div>
                <button class="btn btn-ghost btn-sm" style="margin-top:1rem" @onclick="LoadRemoteAsync">Повторить</button>
            </div>
        }
        else if (_remoteLoading)
        {
            <p style="color:var(--c-text-muted);padding:2rem 0">Загрузка...</p>
        }
        else if (_remoteError)
        {
            <div class="home-card" style="text-align:center;padding:2.5rem;color:var(--c-text-muted)">
                <img src="icons/incloud.svg" style="width:5rem;height:5rem;opacity:.45" />
                <div style="margin-top:.75rem;font-size:.9rem">Не удалось загрузить данные.</div>
                <div style="font-size:.82rem">Проверьте соединение и попробуйте снова.</div>
                <button class="btn btn-ghost btn-sm" style="margin-top:1rem" @onclick="LoadRemoteAsync">Повторить</button>
            </div>
        }
        else if (_remoteItems.Count == 0)
        {
            <div class="home-card" style="text-align:center;padding:2.5rem;color:var(--c-text-muted)">
                <img src="icons/@(_viewMode == 2 ? "shared" : "products").svg" style="width:7.5rem;height:7.5rem;opacity:.6" />
                <div style="margin-top:.5rem;font-size:.9rem">
                    @if (!string.IsNullOrEmpty(_search))
                    { <span>Ничего не найдено по запросу «@_search»</span> }
                    else if (_viewMode == 2)
                    { <span>Никто пока не поделился продуктами.</span> }
                    else
                    { <span>В базовом каталоге пока нет продуктов.</span> }
                </div>
            </div>
        }
        else
        {
            <div class="products-table-wrapper" style="background:#fff;border-radius:12px;border:1px solid var(--c-border);overflow:hidden;box-shadow:var(--s-xs);margin-bottom:1rem">
                <table class="products-table" style="width:100%;border-collapse:collapse;font-size:.9rem">
                    <thead>
                        <tr>
                            <th style="width:52px"></th>
                            <th>Название / Производитель</th>
                            <th>Категория</th>
                            <th>Калории <span class="col-unit">(на 100 г)</span></th>
                            <th>БЖУ <span class="col-unit">(на 100 г)</span></th>
                            <th style="width:88px">Действие</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in _remoteItems)
                        {
                            var p = item.Product;
                            <tr @key="p.Id">
                                <td>
                                    <div class="product-icon-cell">
                                        @if (p.HasImage)
                                        {
                                            <img src="@ProductImageUrl(p)" alt="" class="product-row-img"
                                                 onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
                                        }
                                        <div class="product-cat-icon" style="display:@(p.HasImage ? "none" : "flex")">
                                            @CategoryIcon(p.Category)
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="product-name-cell">
                                        <span class="product-row-name">@p.Name</span>
                                        @if (!string.IsNullOrEmpty(p.Manufacturer))
                                        { <span class="product-row-mfr">@p.Manufacturer</span> }
                                    </div>
                                </td>
                                <td>
                                    <span class="product-cat-badge">@CategoryLabel(p.Category)</span>
                                </td>
                                <td class="product-row-num">@p.CaloriesPer100g.ToString("F0") ккал</td>
                                <td>
                                    <div style="display:flex;flex-direction:column;gap:0;line-height:1.15;font-size:.78rem;font-variant-numeric:tabular-nums;white-space:nowrap">
                                        <span><span style="display:inline-block;width:.9rem;color:var(--c-protein);font-size:.68rem;font-weight:600">Б</span>@p.ProteinPer100g.ToString("F1")</span>
                                        <span><span style="display:inline-block;width:.9rem;color:var(--c-fat);font-size:.68rem;font-weight:600">Ж</span>@p.FatPer100g.ToString("F1")</span>
                                        <span><span style="display:inline-block;width:.9rem;color:var(--c-carbs);font-size:.68rem;font-weight:600">У</span>@p.CarbsPer100g.ToString("F1")</span>
                                    </div>
                                </td>
                                <td>
                                    <div class="product-row-actions">
                                        <button class="row-action-btn"
                                                title="@(item.MyReaction == 1 ? "Убрать из избранного" : "В избранное")"
                                                @onclick="() => ToggleRemoteFavoriteAsync(item)">
                                            <img src="icons/@(item.MyReaction == 1 ? "starFav" : "star").svg" width="20" height="20" />
                                        </button>
                                        <button class="row-action-btn" title="Скрыть" @onclick="() => HideProductAsync(p.Id)">
                                            <img src="icons/unshow.svg" width="18" height="18" />
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    }

    @if (_viewMode == 3)
    {
        <!-- ═══ Скрытые ════════════════════════════════════════════════ -->
        @if (_hiddenLoading)
        {
            <p style="color:var(--c-text-muted);padding:2rem 0">Загрузка...</p>
        }
        else
        {
            var hiddenFiltered = string.IsNullOrEmpty(_search)
                ? _hiddenProducts
                : _hiddenProducts.Where(p => p.Name.Contains(_search, StringComparison.OrdinalIgnoreCase)).ToList();
            @if (hiddenFiltered.Count == 0)
            {
                <div class="home-card" style="text-align:center;padding:2.5rem;color:var(--c-text-muted)">
                    <img src="icons/unshow.svg" style="width:7.5rem;height:7.5rem;opacity:.6" />
                    <div style="margin-top:.5rem;font-size:.9rem">
                        @if (string.IsNullOrEmpty(_search))
                        { <span>Нет скрытых продуктов.</span> }
                        else { <span>Ничего не найдено по запросу «@_search»</span> }
                    </div>
                </div>
            }
            else
            {
                <div class="products-table-wrapper" style="background:#fff;border-radius:12px;border:1px solid var(--c-border);overflow:hidden;box-shadow:var(--s-xs);margin-bottom:1rem">
                    <table class="products-table" style="width:100%;border-collapse:collapse;font-size:.9rem">
                        <thead>
                            <tr>
                                <th style="width:52px"></th>
                                <th>Название / Производитель</th>
                                <th>Категория</th>
                                <th>Калории <span class="col-unit">(на 100 г)</span></th>
                                <th>БЖУ <span class="col-unit">(на 100 г)</span></th>
                                <th style="width:100px">Действие</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var p in hiddenFiltered)
                            {
                                <tr @key="p.Id">
                                    <td>
                                        <div class="product-icon-cell">
                                            @if (p.HasImage)
                                            {
                                                <img src="@ProductImageUrl(p)" alt="" class="product-row-img"
                                                     onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
                                            }
                                            <div class="product-cat-icon" style="display:@(p.HasImage ? "none" : "flex")">
                                                @CategoryIcon(p.Category)
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="product-name-cell">
                                            <span class="product-row-name">@p.Name</span>
                                            @if (!string.IsNullOrEmpty(p.Manufacturer))
                                            { <span class="product-row-mfr">@p.Manufacturer</span> }
                                        </div>
                                    </td>
                                    <td>
                                        <span class="product-cat-badge">@CategoryLabel(p.Category)</span>
                                    </td>
                                    <td class="product-row-num">@p.CaloriesPer100g.ToString("F0") ккал</td>
                                    <td>
                                        <div style="display:flex;flex-direction:column;gap:0;line-height:1.15;font-size:.78rem;font-variant-numeric:tabular-nums;white-space:nowrap">
                                            <span><span style="display:inline-block;width:.9rem;color:var(--c-protein);font-size:.68rem;font-weight:600">Б</span>@p.ProteinPer100g.ToString("F1")</span>
                                            <span><span style="display:inline-block;width:.9rem;color:var(--c-fat);font-size:.68rem;font-weight:600">Ж</span>@p.FatPer100g.ToString("F1")</span>
                                            <span><span style="display:inline-block;width:.9rem;color:var(--c-carbs);font-size:.68rem;font-weight:600">У</span>@p.CarbsPer100g.ToString("F1")</span>
                                        </div>
                                    </td>
                                    <td>
                                        <button class="row-action-btn" title="Показать" @onclick="() => UnhideProductAsync(p.Id)">
                                            <img src="icons/show.svg" width="18" height="18" />
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        }
    }

    <!-- ── Table ───────────────────────────────────────────────────── -->
    @if (_viewMode == 0 && (_loading || _frequentLoading))
    {
        <p style="color:var(--c-text-muted);padding:2rem 0">Загрузка...</p>
    }
    else if (_viewMode == 0)
    {
        var (pageItems, totalItems, totalPages) = GetPagedProducts();

        @if (totalItems == 0)
        {
            <div class="home-card" style="text-align:center;padding:2.5rem;color:var(--c-text-muted)">
                <img src="icons/products.svg" style="width:7.5rem;height:7.5rem;opacity:.6" />
                <div style="margin-top:.5rem;font-size:.9rem">
                    @if (string.IsNullOrEmpty(_search))
                    {
                        @if (_filter == 1) { <span>Нет избранных продуктов. Нажмите ★ в строке продукта.</span> }
                        else if (_filter == 2) { <span>Нет часто используемых продуктов.</span> }
                        else { <span>Нет продуктов. Нажмите «+ Добавить продукт».</span> }
                    }
                    else { <span>Ничего не найдено по запросу «@_search»</span> }
                </div>
            </div>
        }
        else
        {
            <div class="products-table-wrapper" style="background:#fff;border-radius:12px;border:1px solid var(--c-border);overflow:hidden;box-shadow:var(--s-xs);margin-bottom:1rem">
                <table class="products-table" style="width:100%;border-collapse:collapse;font-size:.9rem">
                    <thead>
                        <tr>
                            <th style="width:22px"></th>
                            <th style="width:52px"></th>
                            <th>Название / Производитель</th>
                            <th>Категория</th>
                            <th>Калории <span class="col-unit">(на 100 г)</span></th>
                            <th>БЖУ <span class="col-unit">(на 100 г)</span></th>
                            <th style="width:88px">Действие</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in pageItems)
                        {
                            var isFav = _favoriteIds.Contains(p.Id);
                            var pExpanded = _expandedProductId == p.Id;
                            <tr @key="p.Id" class="product-row-clickable" @onclick="() => ToggleProductExpand(p.Id)">
                                <td>
                                    <span style="font-size:.72rem;color:var(--c-text-muted)">@(pExpanded ? "▾" : "▸")</span>
                                </td>
                                <td>
                                    <div class="product-icon-cell">
                                        @if (_localImageCache.TryGetValue(p.Id, out var cachedImg))
                                        {
                                            <img src="@cachedImg" class="product-row-img" alt="" />
                                        }
                                        else if (p.HasImage)
                                        {
                                            <img src="@ProductImageUrl(p)" alt=""
                                                 class="product-row-img"
                                                 onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
                                            <div class="product-cat-icon" style="display:none">
                                                @CategoryIcon(p.Category)
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="product-cat-icon">
                                                @CategoryIcon(p.Category)
                                            </div>
                                        }
                                    </div>
                                </td>
                                <td>
                                    <div class="product-name-cell">
                                        <span class="product-row-name">@p.Name</span>
                                        @if (!string.IsNullOrEmpty(p.Manufacturer))
                                        {
                                            <span class="product-row-mfr">@p.Manufacturer</span>
                                        }
                                    </div>
                                </td>
                                <td>
                                    <span class="product-cat-badge">@CategoryLabel(p.Category)</span>
                                </td>
                                <td class="product-row-num">@p.CaloriesPer100g.ToString("F0") ккал</td>
                                <td>
                                    <div style="display:flex;flex-direction:column;gap:0;line-height:1.15;font-size:.78rem;font-variant-numeric:tabular-nums;white-space:nowrap">
                                        <span><span style="display:inline-block;width:.9rem;color:var(--c-protein);font-size:.68rem;font-weight:600">Б</span>@p.ProteinPer100g.ToString("F1")</span>
                                        <span><span style="display:inline-block;width:.9rem;color:var(--c-fat);font-size:.68rem;font-weight:600">Ж</span>@p.FatPer100g.ToString("F1")</span>
                                        <span><span style="display:inline-block;width:.9rem;color:var(--c-carbs);font-size:.68rem;font-weight:600">У</span>@p.CarbsPer100g.ToString("F1")</span>
                                    </div>
                                </td>
                                <td @onclick:stopPropagation>
                                    <div class="product-row-actions">
                                        <button class="row-action-btn"
                                                title="@(isFav ? "Убрать из избранного" : "В избранное")"
                                                @onclick="() => ToggleFavoriteAsync(p)">
                                            <img src="icons/@(isFav ? "starFav" : "star").svg" width="20" height="20" />
                                        </button>
                                        <button id="act-btn-@p.Id" class="row-action-btn row-action-btn-dots"
                                                @onclick="async () => await ToggleActionMenuAsync(p.Id)">⋯</button>
                                    </div>
                                </td>
                            </tr>
                            @if (pExpanded)
                            {
                                <tr @key="@($"{p.Id}-exp")" class="product-row-expanded">
                                    <td colspan="7">
                                        <div style="display:flex;gap:1.25rem;padding:.75rem .5rem">
                                            <img src="@(_localImageCache.TryGetValue(p.Id, out var bigImg) ? bigImg : (p.HasImage ? ProductImageUrl(p) : $"icons/{CategoryIconName(p.Category)}.svg"))"
                                                 alt="" style="width:120px;height:120px;border-radius:12px;object-fit:cover;background:var(--c-bg);flex-shrink:0"
                                                 onerror="this.src='icons/@(CategoryIconName(p.Category)).svg'" />
                                            <div style="flex:1;min-width:0;font-size:.85rem">
                                                <div style="display:flex;flex-wrap:wrap;gap:1rem;margin-bottom:.5rem">
                                                    <span>Клетчатка: <b>@p.FiberPer100g.ToString("F1")</b> г</span>
                                                    @if (p.GlycemicIndex.HasValue)
                                                    { <span>ГИ: <b>@p.GlycemicIndex</b></span> }
                                                    @if (p.MeasureType == 1 && p.PieceWeightG.HasValue)
                                                    { <span>Вес 1 шт: <b>@p.PieceWeightG.Value.ToString("F0")</b> г</span> }
                                                </div>
                                                @{ var micros = GetMicronutrients(p); }
                                                @if (micros.Count > 0)
                                                {
                                                    <div style="display:flex;flex-wrap:wrap;gap:.5rem .9rem;color:var(--c-text-muted)">
                                                        @foreach (var (label, value) in micros)
                                                        {
                                                            <span>@label: <b style="color:var(--c-text)">@value.ToString("F1")</b></span>
                                                        }
                                                    </div>
                                                }
                                                else
                                                {
                                                    <div style="color:var(--c-text-muted)">Подробных данных о витаминах и минералах нет.</div>
                                                }
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

            <!-- ── Global action dropdown (fixed, outside table) ──── -->
            @if (_openActionMenu.HasValue && _dropdownTop > 0)
            {
                var ap = pageItems.FirstOrDefault(x => x.Id == _openActionMenu.Value);
                @if (ap != null)
                {
                    <div class="action-dropdown" @onclick:stopPropagation
                         style="position:fixed;top:@(_dropdownTop.ToString("F0"))px;right:@(_dropdownRight.ToString("F0"))px;z-index:9999">
                        @if (ap.UserId.HasValue)
                        {
                            <button @onclick="() => { OpenEdit(ap); _openActionMenu = null; }">
                                <span style="display:flex;align-items:center;gap:.5rem"><img src="icons/edit.svg" width="18" height="18" /> Редактировать</span>
                            </button>
                            @if (ap.OwnerType != 2)
                            {
                                <button @onclick="() => { _ = ShareAsync(ap); _openActionMenu = null; }">
                                    <span style="display:flex;align-items:center;gap:.5rem"><img src="icons/shared.svg" width="18" height="18" /> Поделиться</span>
                                </button>
                            }
                            <button class="danger" @onclick="() => { _pendingDelete = ap; _openActionMenu = null; }">
                                <span style="display:flex;align-items:center;gap:.5rem"><img src="icons/deleted.svg" width="18" height="18" /> Удалить</span>
                            </button>
                        }
                        else
                        {
                            <button @onclick="() => { _ = HideProductAsync(ap.Id); _openActionMenu = null; }">
                                <span style="display:flex;align-items:center;gap:.5rem"><img src="icons/unshow.svg" width="18" height="18" /> Скрыть</span>
                            </button>
                        }
                    </div>
                }
            }

            <!-- ── Pagination ───────────────────────────────────────── -->
            <div class="products-pagination">
                <div class="pagination-pages">
                    <button class="filter-button pgn-btn" disabled="@(_page <= 1)" @onclick="() => _page--">‹</button>
                    @{
                        var shown = new HashSet<int>();
                        for (int i = 1; i <= totalPages; i++)
                        {
                            if (i == 1 || i == totalPages || Math.Abs(i - _page) <= 1)
                            { shown.Add(i); }
                        }
                        int prev2 = 0;
                        foreach (var pg in shown.OrderBy(x => x))
                        {
                            if (prev2 > 0 && pg - prev2 > 1)
                            { <span class="pgn-ellipsis">…</span> }
                            var pgCopy = pg;
                            <button class="filter-button pgn-btn @(pgCopy == _page ? "active" : "")"
                                    @onclick="() => _page = pgCopy">@pgCopy</button>
                            prev2 = pg;
                        }
                    }
                    <button class="filter-button pgn-btn" disabled="@(_page >= totalPages)" @onclick="() => _page++">›</button>
                </div>
                <div class="pagination-size">
                    <span>Показывать по:</span>
                    <select class="form-control" style="width:68px;padding:.2rem .4rem"
                            @bind="_pageSize" @bind:after="() => _page = 1">
                        <option value="10">10</option>
                        <option value="25">25</option>
                        <option value="50">50</option>
                    </select>
                </div>
            </div>
        }
    }
</div>

<!-- ═══════════════════════════════════════════════════════════════════ -->
<!--  Add / Edit Modal                                                   -->
<!-- ═══════════════════════════════════════════════════════════════════ -->
@if (_showModal)
{
    <div class="modal-backdrop">
        <div class="modal-card modal-card-wide" @onclick:stopPropagation>

            <!-- Header -->
            <div class="modal-header">
                <span class="modal-title">@(_editId == Guid.Empty ? "Добавить продукт" : "Редактировать продукт")</span>
                <button class="modal-close" @onclick="CancelEdit">✕</button>
            </div>

            <!-- ── Top-level type switcher ───────────────────────────── -->
            <div class="modal-tabs modal-tabs-type">
                <button class="modal-tab @(!_isComposite ? "modal-tab-active" : string.Empty)"
                        @onclick="() => { _isComposite = false; _modalTab = 0; }">Простой продукт</button>
                <button class="modal-tab @(_isComposite ? "modal-tab-active" : string.Empty)"
                        @onclick="() => { _isComposite = true; _modalTab = 0; }">Составной продукт</button>
            </div>

            @if (!_isComposite)
            {
                <!-- ── Second-level tabs for simple product ──────────── -->
                <div class="modal-tabs modal-tabs-secondary">
                    <button class="modal-tab @(_modalTab == 0 ? "modal-tab-active" : string.Empty)"
                            @onclick="() => _modalTab = 0">Основное</button>
                    <button class="modal-tab @(_modalTab == 1 ? "modal-tab-active" : string.Empty)"
                            @onclick="() => _modalTab = 1">Пищевая ценность</button>
                </div>

                <!-- Tab 0: Основное -->
                @if (_modalTab == 0)
                {
                    <div class="modal-tab-body">
                        <div class="form-group">
                            <label>Название продукта *</label>
                            <input class="form-control" type="text"
                                   placeholder="Например: Куриная грудка" @bind="_name" />
                        </div>
                        <div class="form-group">
                            <label>Производитель</label>
                            <input class="form-control" type="text"
                                   placeholder="Необязательно" @bind="_manufacturer" />
                        </div>
                        <div class="form-group">
                            <label>Категория</label>
                            <select class="form-control" @bind="_category">
                                @foreach (var (val, lbl) in _categories)
                                { <option value="@val">@lbl</option> }
                            </select>
                        </div>
                        <div style="display:grid;grid-template-columns:1fr 1fr;gap:.75rem">
                            <div class="form-group" style="margin:0">
                                <label>Единица измерения</label>
                                <select class="form-control" @bind="_measureType">
                                    <option value="0">По весу (г)</option>
                                    <option value="1">Штучный</option>
                                </select>
                            </div>
                            <div class="form-group" style="margin:0">
                                <label>Порция по умолчанию (г)</label>
                                <input class="form-control" type="number" min="1" step="1" @bind="_defaultServingG" />
                            </div>
                        </div>
                        @if (_measureType == 1)
                        {
                            <div class="form-group">
                                <label>Вес одной штуки (г)</label>
                                <input class="form-control" type="number" min="1" step="1" @bind="_pieceWeightG" />
                            </div>
                        }
                        <div class="form-group">
                            <label>Изображение</label>
                            <div class="img-drop-zone">
                                <InputFile id="img-file-input" OnChange="OnImageSelected" accept=".jpg,.jpeg,.png,.webp"
                                           class="img-drop-input" />
                                @if (_imagePreview is not null)
                                {
                                    <img src="@_imagePreview" class="img-drop-preview" alt="preview" />
                                    <div class="img-drop-overlay">Нажмите или перетащите, чтобы изменить</div>
                                    <button class="img-drop-clear" @onclick="ClearImage" @onclick:stopPropagation title="Удалить изображение">✕</button>
                                }
                                else if (_editId != Guid.Empty && _existingImageUrl is not null)
                                {
                                    <img src="@_existingImageUrl" class="img-drop-preview" alt="фото"
                                         onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
                                    <div class="img-drop-placeholder" style="display:none;position:absolute;inset:0">
                                        <img src="icons/@(CategoryIconName(_category)).svg" width="40" height="40" style="margin-bottom:.4rem;opacity:.7" />
                                        <span>Нажмите или перетащите изображение</span>
                                        <span style="font-size:.75rem;color:var(--c-text-muted)">JPG, PNG, WebP</span>
                                    </div>
                                    <div class="img-drop-overlay">Нажмите или перетащите, чтобы изменить</div>
                                    <button class="img-drop-clear" @onclick="ClearImage" @onclick:stopPropagation title="Удалить изображение">✕</button>
                                }
                                else if (_editId != Guid.Empty)
                                {
                                    <div class="img-drop-placeholder">
                                        <img src="icons/@(CategoryIconName(_category)).svg" width="40" height="40" style="margin-bottom:.4rem;opacity:.7" />
                                        <span>Нажмите или перетащите изображение</span>
                                        <span style="font-size:.75rem;color:var(--c-text-muted)">JPG, PNG, WebP</span>
                                    </div>
                                }
                                else
                                {
                                    <div class="img-drop-placeholder">
                                        <img src="icons/incloud.svg" width="64" height="64" style="opacity:.45;margin-bottom:.4rem" />
                                        <span>Нажмите или перетащите изображение</span>
                                        <span style="font-size:.75rem;color:var(--c-text-muted)">JPG, PNG, WebP</span>
                                    </div>
                                }
                            </div>
                            @if (_imageError is not null)
                            {
                                <div style="font-size:.75rem;color:var(--c-danger);margin-top:.3rem">@_imageError</div>
                            }
                        </div>
                        <div class="modal-toggle-row">
                            <span>Добавить в избранное</span>
                            <label class="toggle-switch">
                                <input type="checkbox" @bind="_addToFavorites" />
                                <span class="toggle-slider"></span>
                            </label>
                        </div>
                    </div>

                    @if (_error is not null)
                    { <div class="alert alert-error" style="margin:.5rem 0">@_error</div> }

                    <div class="modal-footer">
                        <button class="btn btn-ghost" @onclick="CancelEdit">Отмена</button>
                        <button class="btn btn-primary" @onclick="() => _modalTab = 1">Далее</button>
                    </div>
                }

                <!-- Tab 1: Пищевая ценность -->
                @if (_modalTab == 1)
                {
                    <div class="modal-tab-body">
                        <div class="nutrition-grid">
                            <div class="form-group nutrition-cal">
                                <label>Калории * <span style="font-size:.75rem;color:var(--c-text-muted)">(на 100 г)</span></label>
                                <input class="form-control" type="number" min="0" step="0.1"
                                       placeholder="ккал" @bind="_cal" />
                            </div>
                            <div class="form-group">
                                <label><span class="macro-pill macro-pill-protein">Белки (г)</span></label>
                                <input class="form-control" type="number" min="0" step="0.1" @bind="_prot" />
                            </div>
                            <div class="form-group">
                                <label><span class="macro-pill macro-pill-fat">Жиры (г)</span></label>
                                <input class="form-control" type="number" min="0" step="0.1" @bind="_fat" />
                            </div>
                            <div class="form-group">
                                <label><span class="macro-pill macro-pill-carbs">Углеводы (г)</span></label>
                                <input class="form-control" type="number" min="0" step="0.1" @bind="_carbs" />
                            </div>
                            <div class="form-group">
                                <label>Клетчатка (г)</label>
                                <input class="form-control" type="number" min="0" step="0.1" @bind="_fiber" />
                            </div>
                            <div class="form-group">
                                <label>
                                    ГИ
                                    @if (_gi.HasValue)
                                    {
                                        var (giLabel, giColor) = _gi.Value <= 55 ? ("низкий", "#16a34a")
                                            : _gi.Value <= 69 ? ("средний", "#d97706") : ("высокий", "#dc2626");
                                        <span style="font-size:.7rem;padding:.1rem .35rem;border-radius:999px;background:@giColor;color:#fff;margin-left:.3rem">@giLabel</span>
                                    }
                                </label>
                                <input class="form-control" type="number" min="0" max="100" step="1"
                                       @bind="_gi" placeholder="0–100" />
                            </div>
                        </div>

                        <p class="nutrition-section-title" style="color:#3B82F6">Витамины</p>
                        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:.5rem">
                            <div class="form-group"><label style="font-size:.78rem">A (мг)</label><input class="form-control" type="number" min="0" step="0.01" @bind="_vitA" @bind:event="onchange" /></div>
                            <div class="form-group"><label style="font-size:.78rem">C (мг)</label><input class="form-control" type="number" min="0" step="0.1" @bind="_vitC" @bind:event="onchange" /></div>
                            <div class="form-group"><label style="font-size:.78rem">D (мкг)</label><input class="form-control" type="number" min="0" step="0.1" @bind="_vitD" @bind:event="onchange" /></div>
                            <div class="form-group"><label style="font-size:.78rem">B1 (мг)</label><input class="form-control" type="number" min="0" step="0.01" @bind="_vitB1" @bind:event="onchange" /></div>
                            <div class="form-group"><label style="font-size:.78rem">B2 (мг)</label><input class="form-control" type="number" min="0" step="0.01" @bind="_vitB2" @bind:event="onchange" /></div>
                            <div class="form-group"><label style="font-size:.78rem">B3 (мг)</label><input class="form-control" type="number" min="0" step="0.01" @bind="_vitB3" @bind:event="onchange" /></div>
                            <div class="form-group"><label style="font-size:.78rem">B4 (мг)</label><input class="form-control" type="number" min="0" step="0.1" @bind="_vitB4" @bind:event="onchange" /></div>
                            <div class="form-group"><label style="font-size:.78rem">B5 (мг)</label><input class="form-control" type="number" min="0" step="0.01" @bind="_vitB5" @bind:event="onchange" /></div>
                            <div class="form-group"><label style="font-size:.78rem">B6 (мг)</label><input class="form-control" type="number" min="0" step="0.01" @bind="_vitB6" @bind:event="onchange" /></div>
                            <div class="form-group"><label style="font-size:.78rem">B9 (мкг)</label><input class="form-control" type="number" min="0" step="0.1" @bind="_vitB9" @bind:event="onchange" /></div>
                            <div class="form-group"><label style="font-size:.78rem">B12 (мкг)</label><input class="form-control" type="number" min="0" step="0.01" @bind="_vitB12" @bind:event="onchange" /></div>
                            <div class="form-group"><label style="font-size:.78rem">E (мг)</label><input class="form-control" type="number" min="0" step="0.01" @bind="_vitE" @bind:event="onchange" /></div>
                            <div class="form-group"><label style="font-size:.78rem">K (мкг)</label><input class="form-control" type="number" min="0" step="0.1" @bind="_vitK" @bind:event="onchange" /></div>
                            <div class="form-group"><label style="font-size:.78rem">H Биотин (мкг)</label><input class="form-control" type="number" min="0" step="0.1" @bind="_vitH" @bind:event="onchange" /></div>
                        </div>
                        <p class="nutrition-section-title" style="color:#3B82F6">Макроэлементы (мг)</p>
                        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:.5rem">
                            <div class="form-group"><label style="font-size:.78rem">Калий K</label><input class="form-control" type="number" min="0" step="0.1" @bind="_potassium" @bind:event="onchange" /></div>
                            <div class="form-group"><label style="font-size:.78rem">Натрий Na</label><input class="form-control" type="number" min="0" step="0.1" @bind="_sodium" @bind:event="onchange" /></div>
                            <div class="form-group"><label style="font-size:.78rem">Фосфор P</label><input class="form-control" type="number" min="0" step="0.1" @bind="_phosphorus" @bind:event="onchange" /></div>
                            <div class="form-group"><label style="font-size:.78rem">Магний Mg</label><input class="form-control" type="number" min="0" step="0.1" @bind="_magnesium" @bind:event="onchange" /></div>
                            <div class="form-group"><label style="font-size:.78rem">Кальций Ca</label><input class="form-control" type="number" min="0" step="0.1" @bind="_calcium" @bind:event="onchange" /></div>
                            <div class="form-group"><label style="font-size:.78rem">Хлор Cl</label><input class="form-control" type="number" min="0" step="0.1" @bind="_chlorine" @bind:event="onchange" /></div>
                            <div class="form-group"><label style="font-size:.78rem">Сера S</label><input class="form-control" type="number" min="0" step="0.1" @bind="_sulfur" @bind:event="onchange" /></div>
                        </div>
                        <p class="nutrition-section-title" style="color:#3B82F6">Микроэлементы</p>
                        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:.5rem">
                            <div class="form-group"><label style="font-size:.78rem">Железо Fe (мг)</label><input class="form-control" type="number" min="0" step="0.01" @bind="_iron" @bind:event="onchange" /></div>
                            <div class="form-group"><label style="font-size:.78rem">Цинк Zn (мг)</label><input class="form-control" type="number" min="0" step="0.01" @bind="_zinc" @bind:event="onchange" /></div>
                            <div class="form-group"><label style="font-size:.78rem">Марганец Mn (мг)</label><input class="form-control" type="number" min="0" step="0.01" @bind="_manganese" @bind:event="onchange" /></div>
                            <div class="form-group"><label style="font-size:.78rem">Медь Cu (мкг)</label><input class="form-control" type="number" min="0" step="1" @bind="_copper" @bind:event="onchange" /></div>
                            <div class="form-group"><label style="font-size:.78rem">Селен Se (мкг)</label><input class="form-control" type="number" min="0" step="0.1" @bind="_selenium" @bind:event="onchange" /></div>
                            <div class="form-group"><label style="font-size:.78rem">Йод I (мкг)</label><input class="form-control" type="number" min="0" step="0.1" @bind="_iodine" @bind:event="onchange" /></div>
                            <div class="form-group"><label style="font-size:.78rem">Фтор F (мкг)</label><input class="form-control" type="number" min="0" step="0.1" @bind="_fluorine" @bind:event="onchange" /></div>
                            <div class="form-group"><label style="font-size:.78rem">Хром Cr (мкг)</label><input class="form-control" type="number" min="0" step="0.1" @bind="_chromium" @bind:event="onchange" /></div>
                        </div>
                    </div>

                    @if (_error is not null)
                    { <div class="alert alert-error" style="margin:.5rem 0">@_error</div> }

                    <div class="modal-footer">
                        <button class="btn btn-ghost" @onclick="() => _modalTab = 0">Назад</button>
                        <button class="btn btn-primary" @onclick="SaveAsync" disabled="@_saving">
                            @(_saving ? "Сохранение..." : "Сохранить")
                        </button>
                    </div>
                }
            }
            else
            {
                <!-- ── Составной продукт — single form ─────────────────── -->
                <div class="modal-tab-body">
                    <div class="form-group">
                        <label>Название блюда *</label>
                        <input class="form-control" type="text"
                               placeholder="Например: Борщ домашний" @bind="_name" />
                    </div>

                    <div class="form-group">
                        <label>Изображение</label>
                        <div class="img-drop-zone">
                            <InputFile OnChange="OnImageSelected" accept=".jpg,.jpeg,.png,.webp"
                                       class="img-drop-input" />
                            @if (_imagePreview is not null)
                            {
                                <img src="@_imagePreview" class="img-drop-preview" alt="preview" />
                                <div class="img-drop-overlay">Нажмите или перетащите, чтобы изменить</div>
                                <button class="img-drop-clear" @onclick="ClearImage" @onclick:stopPropagation title="Удалить изображение">✕</button>
                            }
                            else if (_editId != Guid.Empty && _existingImageUrl is not null)
                            {
                                <img src="@_existingImageUrl" class="img-drop-preview" alt="фото"
                                     onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
                                <div class="img-drop-placeholder" style="display:none;position:absolute;inset:0">
                                    <img src="icons/@(CategoryIconName(_category)).svg" width="40" height="40" style="margin-bottom:.4rem;opacity:.7" />
                                    <span>Нажмите или перетащите изображение</span>
                                    <span style="font-size:.75rem;color:var(--c-text-muted)">JPG, PNG, WebP</span>
                                </div>
                                <div class="img-drop-overlay">Нажмите или перетащите, чтобы изменить</div>
                                <button class="img-drop-clear" @onclick="ClearImage" @onclick:stopPropagation title="Удалить изображение">✕</button>
                            }
                            else if (_editId != Guid.Empty)
                            {
                                <div class="img-drop-placeholder">
                                    <img src="icons/@(CategoryIconName(_category)).svg" width="40" height="40" style="margin-bottom:.4rem;opacity:.7" />
                                    <span>Нажмите или перетащите изображение</span>
                                    <span style="font-size:.75rem;color:var(--c-text-muted)">JPG, PNG, WebP</span>
                                </div>
                            }
                            else
                            {
                                <div class="img-drop-placeholder">
                                    <img src="icons/incloud.svg" width="64" height="64" style="opacity:.45;margin-bottom:.4rem" />
                                    <span>Нажмите или перетащите изображение</span>
                                    <span style="font-size:.75rem;color:var(--c-text-muted)">JPG, PNG, WebP</span>
                                </div>
                            }
                        </div>
                        @if (_imageError is not null)
                        {
                            <div style="font-size:.75rem;color:var(--c-danger);margin-top:.3rem">@_imageError</div>
                        }
                    </div>

                    <!-- Ingredients -->
                    <div class="form-card">
                        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:.75rem">
                            <strong>Ингредиенты</strong>
                            @if (_ingredients.Count > 0)
                            {
                                <span style="font-size:.8rem;color:var(--c-text-muted)">
                                    @_ingredients.Sum(i => i.Grams).ToString("F0") г →
                                    @(_totalYieldG > 0 ? _totalYieldG.ToString("F0") : _ingredients.Sum(i => i.Grams).ToString("F0")) г
                                </span>
                            }
                        </div>
                        @foreach (var item in _ingredients)
                        {
                            var idx = _ingredients.IndexOf(item);
                            var ip = _allProducts.FirstOrDefault(x => x.Id == item.ProductId);
                            <div class="home-card" style="padding:.4rem .65rem;margin-bottom:.5rem;display:flex;gap:.6rem;align-items:center">
                                <div class="product-icon-cell" style="flex-shrink:0">
                                    @if (ip is { HasImage: true })
                                    {
                                        <img src="@ProductImageUrl(ip)" alt="" class="product-row-img"
                                             onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
                                    }
                                    <div class="product-cat-icon" style="display:@(ip is { HasImage: true } ? "none" : "flex")">
                                        <img src="icons/@(ProductCategories.IconName(ip?.Category ?? 0)).svg" />
                                    </div>
                                </div>
                                <div style="flex:1;min-width:0;font-size:.875rem;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">@item.Name</div>
                                <input class="form-control" type="number" min="1" step="1" style="width:80px;flex-shrink:0"
                                       value="@item.Grams"
                                       @onchange="e => UpdateIngGrams(idx, double.TryParse(e.Value?.ToString(), out var g) ? g : item.Grams)" />
                                <span style="font-size:.8rem;color:var(--c-text-muted);flex-shrink:0">г</span>
                                <button class="btn btn-ghost btn-icon btn-sm" style="flex-shrink:0" @onclick="() => _ingredients.RemoveAt(idx)">✕</button>
                            </div>
                        }
                        <div class="form-group" style="margin-bottom:.5rem">
                            <div style="display:flex;gap:.5rem">
                                <input class="form-control" type="text" placeholder="Добавить ингредиент..." style="flex:1"
                                       @bind="_ingSearch" @oninput="SearchIngredients" />
                                <button class="btn btn-ghost btn-sm" style="flex-shrink:0" @onclick="() => _showIngCatalog = true"><img src="icons/catalog.svg" width="32" height="32" /> Каталог</button>
                            </div>
                            @if (_ingResults.Count > 0)
                            {
                                <div class="search-results">
                                    @foreach (var p in _ingResults)
                                    {
                                        <ProductSearchResultItem Product="p" OnClick="AddIngredient" />
                                    }
                                </div>
                            }
                        </div>
                        <div class="form-group" style="margin-bottom:0">
                            <label>Выход готового блюда (г)</label>
                            <input class="form-control" type="number" min="1" step="1"
                                   @bind="_totalYieldG" placeholder="0 = сумма ингредиентов" />
                        </div>
                    </div>

                    <!-- Read-only computed nutrition -->
                    @{
                        var cn = CalcCompositeNutrients();
                        var hasIng = _ingredients.Count > 0;
                    }
                    <div class="composite-nutrition-preview @(hasIng ? string.Empty : "composite-nutrition-empty")">
                        <div class="composite-nutrition-title">Пищевая ценность (на 100 г) — авторасчёт</div>
                        <div class="composite-nutrition-grid">
                            <div class="composite-nutrition-item">
                                <span class="composite-nutrition-val">@(hasIng ? cn.Cal.ToString("F0") : "—")</span>
                                <span class="composite-nutrition-lbl">ккал</span>
                            </div>
                            <div class="composite-nutrition-item">
                                <span class="composite-nutrition-val">@(hasIng ? cn.Prot.ToString("F1") : "—")</span>
                                <span class="composite-nutrition-lbl">белки</span>
                            </div>
                            <div class="composite-nutrition-item">
                                <span class="composite-nutrition-val">@(hasIng ? cn.Fat.ToString("F1") : "—")</span>
                                <span class="composite-nutrition-lbl">жиры</span>
                            </div>
                            <div class="composite-nutrition-item">
                                <span class="composite-nutrition-val">@(hasIng ? cn.Carbs.ToString("F1") : "—")</span>
                                <span class="composite-nutrition-lbl">углеводы</span>
                            </div>
                        </div>
                    </div>
                </div>

                @if (_error is not null)
                { <div class="alert alert-error" style="margin:.5rem 0">@_error</div> }

                <div class="modal-footer">
                    <button class="btn btn-ghost" @onclick="CancelEdit">Отмена</button>
                    <button class="btn btn-primary" @onclick="SaveAsync" disabled="@_saving">
                        @(_saving ? "Сохранение..." : "Сохранить")
                    </button>
                </div>
            }

        </div>
    </div>
}

