    private static string SourceLabel(string src) => src switch
    {
        "mine"   => "мой",
        "base"   => "база",
        "shared" => "от пользователей",
        _ => src
    };

    private static string ProductImageUrl(Guid id) => $"/api/products/{id}/image";

    private async Task UploadImageAsync(Guid productId, IBrowserFile file)
    {
        try
        {
            using var content = new MultipartFormDataContent();
            var stream = file.OpenReadStream(2 * 1024 * 1024);
            content.Add(new StreamContent(stream), "file", file.Name);
            await Http.PostAsync($"/api/products/{productId}/image", content);
        }
        catch { /* ignore upload errors — product is saved */ }
    }

    RenderFragment ProductList(List<ProductDto> items, bool mine) =>
        @<div style="display:flex;flex-direction:column;gap:.5rem">
            @foreach (var p in items)
            {
                var imgUrl = ProductImageUrl(p.Id);
                <div class="home-card" style="padding:.16rem .16rem">
                    <div style="display:flex;align-items:flex-start;gap:.75rem">
                        <img src="@imgUrl" alt=""
                             style="width:64px;height:64px;object-fit:cover;border-radius:var(--r-md);border:1px solid var(--c-border);flex-shrink:0"
                             onerror="this.style.display='none'" />
                        <div style="flex:1;min-width:0">
                            <div style="display:flex;align-items:center;gap:.5rem;flex-wrap:wrap">
                                <span style="font-weight:600;font-size:.95rem">@p.Name</span>
                                @if (p.OwnerType == 2)
                                { <span class="product-badge shared">поделился</span> }
                                @if (p.IsComposite)
                                { <span class="product-badge composite">составной</span> }
                                @if (p.MeasureType == 1)
                                { <span class="product-badge piece">штучный · @((p.PieceWeightG ?? 0).ToString("F0"))г/шт</span> }
                            </div>
                            <div style="font-size:.8rem;color:var(--c-text-muted);margin-top:.2rem">
                                @p.CaloriesPer100g.ToString("F0") ккал ·
                                Б&nbsp;@p.ProteinPer100g.ToString("F1") ·
                                Ж&nbsp;@p.FatPer100g.ToString("F1") ·
                                У&nbsp;@p.CarbsPer100g.ToString("F1")
                                &nbsp;(на 100 г)
                            </div>
                            @if (p.IsComposite && p.Ingredients?.Count > 0)
                            {
                                <div style="font-size:.75rem;color:var(--c-text-muted);margin-top:.2rem">
                                    @string.Join(", ", p.Ingredients.Select(i => i.IngredientName))
                                </div>
                            }
                        </div>
                        @if (mine)
                        {
                            <div style="display:flex;gap:.25rem">
                                @if (p.OwnerType != 2)
                                {
                                    <button class="btn btn-ghost btn-icon btn-sm" title="Поделиться"
                                            @onclick="() => ShareAsync(p)">🌐</button>
                                }
                                <button class="btn btn-ghost btn-icon btn-sm" title="Редактировать"
                                        @onclick="() => OpenEdit(p)">✏️</button>
                                <button class="btn btn-ghost btn-icon btn-sm" title="Удалить"
                                        @onclick="() => DeleteAsync(p)">🗑</button>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>;

    private static double? ParseNullable(object? v) =>
        double.TryParse(v?.ToString(), out var d) && d > 0 ? d : null;

    private record IngredientItem(Guid ProductId, string Name, double Grams);

    // Needed for ProductSearchItemDto with expression
    private record ProductSearchItemDto(
        ProductDto Product, int UseCount, int? MyReaction, string Source);
