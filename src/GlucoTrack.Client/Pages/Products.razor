@code {
    // ── Data ──────────────────────────────────────────────────────────────────
    private bool _loading = true;
    private List<ProductDto> _myProducts = [];
    private List<ProductDto> _allProducts = [];
    private List<ProductDto> _frequent = [];
    private bool _frequentLoading;
    private HashSet<Guid> _favoriteIds = [];

    // ── Filter / pagination ───────────────────────────────────────────────────
    private int _filter = 3;          // 1=Favorites 2=Frequent 3=Mine (default) 4=Category
    private int? _catFilter;
    private bool _catDropdownOpen;
    private string _search = "";
    private int _page = 1;
    private int _pageSize = 10;

    // ── Menus ─────────────────────────────────────────────────────────────────
    private Guid? _openActionMenu;
    private double _dropdownTop;
    private double _dropdownRight;

    // ── Modal ─────────────────────────────────────────────────────────────────
    private bool _showModal;
    private ProductDto? _pendingDelete;
    private int _modalTab; // 0 = Основное, 1 = Пищевая ценность
    private bool _saving;
    private string? _error;
    private Guid _editId = Guid.Empty;

    // Form fields
    private string _name = "", _manufacturer = "";
    private int _category, _measureType;
    private double _pieceWeightG, _defaultServingG = 100;
    private bool _isComposite;
    private double _totalYieldG;
    private bool _addToFavorites;

    // Nutrients
    private double _cal, _prot, _fat, _carbs, _fiber;
    private int? _gi;
    private double? _vitA, _vitC, _vitD, _vitB1, _vitB2, _vitB3, _vitB4, _vitB5, _vitB6,
                    _vitB9, _vitB12, _vitE, _vitK, _vitH;
    private double? _calcium, _phosphorus, _potassium, _sodium, _chlorine, _magnesium,
                    _sulfur, _iron, _zinc, _selenium, _iodine, _manganese, _copper,
                    _fluorine, _chromium;

    // Image
    private byte[]? _imageBytes;
    private string? _imageFileName;
    private string? _imagePreview, _imageError, _existingImageUrl;
    private readonly Dictionary<Guid, string> _localImageCache = new();

    // Composite ingredients
    private List<IngredientItem> _ingredients = [];
    private List<ProductDto> _ingResults = [];
    private string _ingSearch = "";

    // ── View mode / accordion ────────────────────────────────────────────────
    private int _viewMode; // 0 = Продукты, 1 = Шаблоны меню, 2 = От сообщества, 3 = Скрытые, 4 = Базовые
    private Guid? _expandedProductId;
    private Guid? _expandedTplId;
    private bool _templatesLoading, _templatesLoaded;

    // ── Shared / Base (live) / Hidden ───────────────────────────────────────────
    private List<ProductSearchItemDto> _remoteItems = [];
    private bool _remoteLoading, _remoteError;
    private List<ProductDto> _hiddenProducts = [];
    private bool _hiddenLoading, _hiddenLoaded;

    // ── Templates ────────────────────────────────────────────────────────────
    private List<MealTemplateDto> _templates = [];
    private bool _tplEditing, _tplSaving, _showTplCatalog, _showIngCatalog;
    private Guid _tplEditId = Guid.Empty;
    private string _tplName = "", _tplSearch = "";
    private string? _tplError, _tplApplied;
    private List<PlannedMealItem> _tplItems = [];
    private List<ProductDto> _tplSearchResults = [];
    private byte[]? _tplImageBytes;
    private string? _tplImageFileName, _tplImagePreview, _tplExistingImageUrl, _tplImageError;

    // ── Constants ─────────────────────────────────────────────────────────────
    private static readonly (int val, string lbl)[] _categories =
    [
        (0,"Прочее"), (1,"Мясо"), (2,"Рыба"), (3,"Молочные"), (4,"Злаки"),
        (5,"Овощи"), (6,"Фрукты"), (7,"Выпечка"), (8,"Напитки"),
        (9,"Орехи"), (10,"Сладкое"), (11,"Яйца"), (12,"Бобовые"),
        (13,"Кисломолочные"), (14,"Колбасы"), (15,"Алкоголь"), (16,"Макароны"),
        (17,"Полуфабрикаты"), (18,"Грибы"), (19,"Мясо птицы"), (20,"Соусы")
    ];

    // ── Lifecycle ─────────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        await LoadMyProductsAsync();
        _ = LoadFavoriteIdsAsync();
    }

    private async Task LoadMyProductsAsync()
    {
        _loading = true;
        _myProducts = (await Db.GetAllAsync<ProductDto>("products"))
            .Where(p => !p.IsDeleted).ToList();
        _allProducts = _myProducts;
        _loading = false;
    }

    private async Task LoadFavoriteIdsAsync()
    {
        try
        {
            var favs = await Http.GetFromJsonAsync<List<ProductDto>>("/api/products/favorites");
            _favoriteIds = (favs ?? []).Select(p => p.Id).ToHashSet();
            StateHasChanged();
        }
        catch { }
    }

    private async Task LoadFrequentAsync()
    {
        _frequentLoading = true;
        try
        {
            var url = "/api/products/search?source=mine&q=&take=100";
            var result = await Http.GetFromJsonAsync<List<ProductSearchItemDto>>(url);
            _frequent = (result ?? [])
                .Where(r => r.UseCount > 0)
                .OrderByDescending(r => r.UseCount)
                .Select(r => r.Product)
                .ToList();
        }
        catch { _frequent = []; }
        _frequentLoading = false;
    }

    // ── Filter logic ──────────────────────────────────────────────────────────

    private async Task SetFilter(int f)
    {
        _viewMode = 0;
        _filter = f;
        _catDropdownOpen = false;
        _page = 1;
        if (f == 2 && _frequent.Count == 0)
            await LoadFrequentAsync();
    }

    private void CloseAllDropdowns()
    {
        _catDropdownOpen = false;
        _openActionMenu = null;

    }

    private void ToggleCatDropdown()
    {
        _viewMode = 0;
        _catDropdownOpen = !_catDropdownOpen;
    }

    private void SelectCategory(int? val)
    {
        _viewMode = 0;
        _catFilter = val;
        _filter = val.HasValue ? 4 : 3;
        _catDropdownOpen = false;
        _page = 1;
    }

    private async Task ToggleActionMenuAsync(Guid id)
    {
        if (_openActionMenu == id) { _openActionMenu = null; return; }
        _openActionMenu = id;

        _catDropdownOpen = false;
        try
        {
            var rect = await JS.InvokeAsync<JsonElement>("getBoundingRect", $"act-btn-{id}");
            _dropdownTop = rect.GetProperty("top").GetDouble() + 4;
            _dropdownRight = rect.GetProperty("right").GetDouble();
        }
        catch { _dropdownTop = 100; _dropdownRight = 16; }
    }

    // ── Paging ────────────────────────────────────────────────────────────────

    private (List<ProductDto> items, int total, int totalPages) GetPagedProducts()
    {
        // The base catalog is no longer bulk-synced (see PullAsync), so _myProducts only
        // ever contains your own products — no need to filter by ownership or dedupe clones.
        var source = _filter switch
        {
            1 => _myProducts.Where(p => _favoriteIds.Contains(p.Id)),
            2 => _frequent.AsEnumerable(),
            4 => _catFilter.HasValue
                    ? _myProducts.Where(p => p.Category == _catFilter.Value)
                    : _myProducts.AsEnumerable(),
            _ => _myProducts.AsEnumerable()
        };

        if (!string.IsNullOrEmpty(_search))
            source = source.Where(p => p.Name.Contains(_search, StringComparison.OrdinalIgnoreCase)
                                    || (!string.IsNullOrEmpty(p.Manufacturer) && p.Manufacturer.Contains(_search, StringComparison.OrdinalIgnoreCase)));

        var list = source.OrderBy(p => p.Name).ToList();
        int total = list.Count;
        int totalPages = Math.Max(1, (int)Math.Ceiling(total / (double)_pageSize));
        _page = Math.Clamp(_page, 1, totalPages);
        var items = list.Skip((_page - 1) * _pageSize).Take(_pageSize).ToList();
        return (items, total, totalPages);
    }

    // ── Favorites ─────────────────────────────────────────────────────────────

    private async Task ToggleFavoriteAsync(ProductDto p)
    {
        bool isFav = _favoriteIds.Contains(p.Id);
        int newReaction = isFav ? 0 : 1;
        try
        {
            await Http.PostAsJsonAsync($"/api/products/{p.Id}/react", new { reaction = newReaction });
            if (newReaction == 1) _favoriteIds.Add(p.Id);
            else _favoriteIds.Remove(p.Id);
        }
        catch { }
    }

    // ── Form open/close ───────────────────────────────────────────────────────

    private void OpenAdd()
    {
        ResetForm();
        _modalTab = 0;
        _showModal = true;

    }

    private void OpenEdit(ProductDto p)
    {
        ResetForm();
        _imageBytes = null; _imageFileName = null; _imagePreview = null; _imageError = null;
        _existingImageUrl = ProductImageUrl(p);
        _editId = p.Id; _name = p.Name; _manufacturer = p.Manufacturer ?? "";
        _category = p.Category; _measureType = p.MeasureType;
        _pieceWeightG = p.PieceWeightG ?? 0; _defaultServingG = p.DefaultServingG;
