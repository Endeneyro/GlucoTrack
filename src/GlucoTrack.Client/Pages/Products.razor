    private async Task OnImageSelected(InputFileChangeEventArgs e)
    {
        _imageError = null;
        try
        {
            var file = e.File;
            const long maxBytes = 8 * 1024 * 1024;
            if (file.Size > maxBytes) { _imageError = "Макс. 8 МБ."; return; }
            var ext = Path.GetExtension(file.Name).ToLowerInvariant();
            if (ext is not (".jpg" or ".jpeg" or ".png" or ".webp"))
            { _imageError = "Допустимые форматы: JPG, PNG, WebP."; return; }

            // Buffer immediately — IBrowserFile becomes invalid after re-render
            await using var stream = file.OpenReadStream(maxBytes);
            var buf = new byte[file.Size];
            _ = await stream.ReadAsync(buf);

            _imageBytes = buf;
            _imageFileName = file.Name;
            var mime = ext == ".png" ? "image/png" : ext == ".webp" ? "image/webp" : "image/jpeg";
            _imagePreview = $"data:{mime};base64,{Convert.ToBase64String(buf)}";
        }
        catch { _imageError = "Не удалось загрузить файл. Попробуйте ещё раз."; }
    }

    // ── Save ──────────────────────────────────────────────────────────────────

    private async Task SaveAsync()
    {
        if (string.IsNullOrWhiteSpace(_name)) { _error = "Введите название продукта"; return; }

        double cal = _cal, prot = _prot, fat = _fat, carbs = _carbs, fiber = _fiber;
        if (_isComposite)
        {
            if (_ingredients.Count == 0) { _error = "Добавьте хотя бы один ингредиент"; return; }
            var p = CalcCompositeNutrients();
            cal = p.Cal; prot = p.Prot; fat = p.Fat; carbs = p.Carbs; fiber = p.Fiber;
        }
        else if (cal <= 0) { _error = "Укажите калорийность"; return; }

        _saving = true; _error = null;

        var ingredients = _isComposite
            ? _ingredients.Select(i => new ProductIngredientDto(Guid.NewGuid(), i.ProductId, i.Name, i.Grams)).ToList()
            : null;

        ProductDto dto = new ProductDto(
            _editId == Guid.Empty ? Guid.NewGuid() : _editId,
            null, _name.Trim(),
            _category, 1, _measureType,
            _pieceWeightG > 0 ? _pieceWeightG : null,
            _defaultServingG > 0 ? _defaultServingG : 100,
            _isComposite, _totalYieldG > 0 ? _totalYieldG : null,
            false, null, 0, 0,
            _gi,
            cal, prot, fat, carbs, fiber,
            _vitA, _vitC, _vitD,
            _vitB1, _vitB2, _vitB3, _vitB4, _vitB5, _vitB6,
            _vitB9, _vitB12, _vitE, _vitK, _vitH,
            _calcium, _phosphorus, _potassium,
            _sodium, _chlorine, _magnesium,
            _sulfur, _iron, _zinc, _selenium, _iodine,
            _manganese, _copper, _fluorine, _chromium,
            ingredients, DateTime.UtcNow, false,
            string.IsNullOrWhiteSpace(_manufacturer) ? null : _manufacturer.Trim());

        await Db.PutAsync("products", dto, pending: true);

        if (_imageBytes is not null)
        {
            await Sync.SyncAsync();
            await UploadImageAsync(dto.Id, _imageBytes, _imageFileName ?? "image.jpg");
            // Bump UpdatedAtUtc so the image URL cache-busting param changes in the list
            dto = dto with { UpdatedAtUtc = DateTime.UtcNow };
        }
        else
        {
            _ = Sync.SyncAsync();
        }

        if (_addToFavorites && !_favoriteIds.Contains(dto.Id))
        {
            try
            {
                await Sync.SyncAsync();
                await Http.PostAsJsonAsync($"/api/products/{dto.Id}/react", new { reaction = 1 });
                _favoriteIds.Add(dto.Id);
            }
            catch { }
        }

        _saving = false;
        _showModal = false;
        if (_imagePreview is not null)
            _localImageCache[dto.Id] = _imagePreview;
        _imageBytes = null; _imageFileName = null; _imagePreview = null;

        // Update in-memory list immediately so UI reflects the change without reload
        if (_editId == Guid.Empty)
        {
            _myProducts.Add(dto);
        }
        else
        {
            var idx = _myProducts.FindIndex(p => p.Id == dto.Id);
            if (idx >= 0) _myProducts[idx] = dto;
        }
        _allProducts = _myProducts;
        _editId = Guid.Empty;
    }

    private async Task ConfirmDeleteAsync()
    {
        if (_pendingDelete is null) return;
        var p = _pendingDelete;
        _pendingDelete = null;

        _myProducts.Remove(p);
        _allProducts = _myProducts;
        _favoriteIds.Remove(p.Id);
        _localImageCache.Remove(p.Id);

        await Db.PutAsync("products", p with { IsDeleted = true, UpdatedAtUtc = DateTime.UtcNow }, pending: true);
        _ = Sync.SyncAsync();
    }

