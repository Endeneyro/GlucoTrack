    private void UpdateIngGrams(int idx, double g)
    {
        if (idx < _ingredients.Count)
            _ingredients[idx] = _ingredients[idx] with { Grams = g };
    }

    private (double Cal, double Prot, double Fat, double Carbs, double Fiber) CalcCompositeNutrients()
    {
        double totalInput = _ingredients.Sum(i => i.Grams);
        double yield = _totalYieldG > 0 ? _totalYieldG : totalInput;
        if (yield <= 0) yield = 1;
        double cal = 0, prot = 0, fat = 0, carbs = 0, fiber = 0;
        var map = _allProducts.ToDictionary(p => p.Id);
        foreach (var ing in _ingredients)
        {
            if (!map.TryGetValue(ing.ProductId, out var p)) continue;
            double k = ing.Grams / 100.0;
            cal += p.CaloriesPer100g * k; prot += p.ProteinPer100g * k;
            fat += p.FatPer100g * k; carbs += p.CarbsPer100g * k; fiber += p.FiberPer100g * k;
        }
        double f = 100.0 / yield;
        return (cal * f, prot * f, fat * f, carbs * f, fiber * f);
    }

