    private async Task TplSaveAsync()
    {
        if (string.IsNullOrWhiteSpace(_tplName)) { _tplError = "Введите название"; return; }
        if (_tplItems.Count == 0) { _tplError = "Добавьте хотя бы один продукт"; return; }
        _tplSaving = true; _tplError = null;
        var existingHasImage = _templates.FirstOrDefault(t => t.Id == _tplEditId)?.HasImage ?? false;
        var dto = new MealTemplateDto(
            _tplEditId == Guid.Empty ? Guid.NewGuid() : _tplEditId,
            _tplName.Trim(), _tplItems, DateTime.UtcNow, false, existingHasImage);
        await Db.PutAsync("meal_templates", dto, pending: true);
        var idx = _templates.FindIndex(t => t.Id == dto.Id);
        if (idx >= 0) _templates[idx] = dto; else _templates.Add(dto);
        _tplSaving = false; _tplEditing = false;

        if (_tplImageBytes is not null)
        {
            await Sync.SyncAsync();
            await UploadTplImageAsync(dto.Id, _tplImageBytes, _tplImageFileName ?? "image.jpg");
            dto = dto with { UpdatedAtUtc = DateTime.UtcNow, HasImage = true };
            await Db.PutAsync("meal_templates", dto, pending: false);
            idx = _templates.FindIndex(t => t.Id == dto.Id);
            if (idx >= 0) _templates[idx] = dto;
        }
        else
        {
            _ = Sync.SyncAsync();
        }
    }

