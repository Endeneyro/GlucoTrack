    private async Task TplApplyAsync(MealTemplateDto tpl)
    {
        var today = DateOnly.FromDateTime(DateTime.Today);
        var now = TimeOnly.FromDateTime(DateTime.Now);
        foreach (var item in tpl.Items)
        {
            var dto = new MealEntryDto(
                Guid.NewGuid(), today, now,
                (int)GlucoTrack.Shared.Entities.MealType.Snack,
                item.ProductId, item.Grams,
                DateTime.UtcNow, false);
            await Db.PutAsync("meals", dto, pending: true);
        }
        _ = Sync.SyncAsync();
        _tplApplied = tpl.Name;
        await Task.Delay(3000);
        _tplApplied = null;
    }

    private double TplKcal(MealTemplateDto tpl)
    {
        double total = 0;
        foreach (var i in tpl.Items)
        {
            var p = _allProducts.FirstOrDefault(x => x.Id == i.ProductId);
            if (p is null) continue;
            total += p.CaloriesPer100g * NutritionMath(p, i.Grams);
        }
        return total;
    }

    private double TplNutrient(MealTemplateDto tpl, Func<ProductDto, double> selector)
    {
        double total = 0;
        foreach (var i in tpl.Items)
        {
            var p = _allProducts.FirstOrDefault(x => x.Id == i.ProductId);
            if (p is null) continue;
            total += selector(p) * NutritionMath(p, i.Grams);
        }
        return total;
    }

    private static double NutritionMath(ProductDto p, double grams)
    {
        var effG = p.MeasureType == 1 ? grams * (p.PieceWeightG ?? 100) : grams;
        return effG / 100.0;
    }

    private double TplPreviewKcal() => _tplItems.Sum(i =>
