    {
        _hiddenLoading = true;
        try
        {
            var result = await Http.GetFromJsonAsync<List<ProductDto>>("/api/products/hidden");
            _hiddenProducts = result ?? [];
        }
        catch { _hiddenProducts = []; }
        _hiddenLoading = false;
    }

    private async Task ToggleRemoteFavoriteAsync(ProductSearchItemDto item)
    {
        int newReaction = item.MyReaction == 1 ? 0 : 1;
        try
        {
            await Http.PostAsJsonAsync($"/api/products/{item.Product.Id}/react", new { reaction = newReaction });
            var idx = _remoteItems.FindIndex(x => x.Product.Id == item.Product.Id);
            if (idx >= 0) _remoteItems[idx] = item with { MyReaction = newReaction == 0 ? null : newReaction };
            // The favorite may have just been cloned into the user's own products server-side — sync it down.
            _ = Sync.SyncAsync();
        }
        catch { }
    }

