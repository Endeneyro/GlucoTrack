    // ── Insulin CRUD ──────────────────────────────────────────────────────────

    private void StartAddInsulin()
    {
        _editInsulinId = Guid.Empty; _insName = ""; _insNote = "";
        _insType = 0; _insDose = null; _insActive = true; _insError = null;
        _editingInsulin = true;
    }

    private void StartEditInsulin(UserInsulinDto ins)
    {
        _editInsulinId = ins.Id; _insName = ins.Name; _insNote = ins.Note ?? "";
        _insType = ins.InsulinType; _insDose = ins.TypicalDose;
        _insActive = ins.IsActive; _insError = null;
        _editingInsulin = true;
    }

    private void CancelInsulinEdit() { _editingInsulin = false; _insError = null; }

    private async Task SaveInsulinAsync()
    {
        if (string.IsNullOrWhiteSpace(_insName)) { _insError = "Введите название инсулина"; return; }
        _savingInsulin = true; _insError = null;

        var dto = new UserInsulinDto(
            _editInsulinId == Guid.Empty ? Guid.NewGuid() : _editInsulinId,
            _insName.Trim(), _insType, _insDose, _insActive,
            string.IsNullOrWhiteSpace(_insNote) ? null : _insNote.Trim(),
            DateTime.UtcNow, false);

        await Db.PutAsync("user_insulins", dto, pending: true);
        _ = Sync.SyncAsync();

        var idx = _insulins.FindIndex(i => i.Id == dto.Id);
        if (idx >= 0) _insulins[idx] = dto;
        else _insulins.Add(dto);

        _savingInsulin = false;
        _editingInsulin = false;
    }

    private async Task DeleteInsulinAsync(UserInsulinDto ins)
    {
        var deleted = ins with { IsDeleted = true, UpdatedAtUtc = DateTime.UtcNow };
        await Db.PutAsync("user_insulins", deleted, pending: true);
        _ = Sync.SyncAsync();
        _insulins.RemoveAll(i => i.Id == ins.Id);
    }

    // ── Therapy coefficients ──────────────────────────────────────────────────

    private async Task AddCoeffAsync()
    {
        _coeffErr = null;
        if (!TimeOnly.TryParse(_cFrom, out var from) || !TimeOnly.TryParse(_cTo, out var to))
        { _coeffErr = "Неверный формат времени"; return; }
        if (_cIc <= 0 || _cIsf <= 0)
        { _coeffErr = "IC и ISF должны быть больше 0"; return; }

        var dto = new TherapyCoeffDto(Guid.NewGuid(), from, to, _cIc, _cIsf, DateTime.UtcNow, false);
        await Db.PutAsync("therapy", dto, pending: true);
        _coeffs.Add(dto);
        _ = Sync.SyncAsync();
    }

    private async Task DeleteCoeffAsync(Guid id)
    {
        var existing = _coeffs.FirstOrDefault(c => c.Id == id);
        if (existing is null) return;
        var deleted = existing with { IsDeleted = true, UpdatedAtUtc = DateTime.UtcNow };
        await Db.PutAsync("therapy", deleted, pending: true);
        _coeffs.RemoveAll(c => c.Id == id);
        _ = Sync.SyncAsync();
    }

    private async Task CalcFromDataAsync()
    {
        _calcLoading = true; _calcError = null; _calcResult = null;
        StateHasChanged();
        try
        {
            var since = DateTime.UtcNow.AddDays(-14).Date;
            var insulin = (await Db.GetAllAsync<InsulinInjectionDto>("insulin"))
                .Where(i => !i.IsDeleted && i.InjectedAtUtc >= since).ToList();
            var glucose = (await Db.GetAllAsync<GlucoseReadingDto>("glucose"))
                .Where(g => !g.IsDeleted && g.MeasuredAtUtc >= since).ToList();

            if (insulin.Count == 0)
            { _calcError = "Нет данных об инсулине за последние 14 дней."; return; }

            var glucoseByDay = glucose
                .GroupBy(g => g.MeasuredAtUtc.ToLocalTime().Date)
                .ToDictionary(g => g.Key, g => (Min: g.Min(x => x.ValueMmol), Max: g.Max(x => x.ValueMmol)));

            var insulinByDay = insulin
                .GroupBy(i => i.InjectedAtUtc.ToLocalTime().Date)
                .ToDictionary(g => g.Key, g => g.Sum(x => x.Units));

            var goodDays = new List<double>(); int excluded = 0;
            foreach (var (day, tdd) in insulinByDay)
            {
                if (glucoseByDay.TryGetValue(day, out var ex) && (ex.Min < 3.5 || ex.Max > 15))
                { excluded++; continue; }
                goodDays.Add(tdd);
            }

            if (goodDays.Count < 3)
            { _calcError = $"Недостаточно обычных дней (нужно минимум 3, доступно {goodDays.Count})."; return; }

            double avgTdd = goodDays.Average();
            _calcResult = new(Math.Round(avgTdd, 1), Math.Round(500.0 / avgTdd, 1),
                Math.Round(100.0 / avgTdd, 2), goodDays.Count, excluded);
        }
        finally { _calcLoading = false; }
    }

    private async Task ApplyCalcResult()
    {
        if (_calcResult is null) return;
        var dto = new TherapyCoeffDto(Guid.NewGuid(), TimeOnly.MinValue, new TimeOnly(23, 59),
            _calcResult.Ic, _calcResult.Isf, DateTime.UtcNow, false);
        await Db.PutAsync("therapy", dto, pending: true);
        _coeffs.Add(dto);
        _ = Sync.SyncAsync();
        _calcResult = null;
    }

