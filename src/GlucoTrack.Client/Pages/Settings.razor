@page "/settings"
@attribute [Authorize]
@using GlucoTrack.Shared.DTOs.Sync
@inject DbService Db
@inject SyncService Sync
@inject NavigationManager Nav

<PageTitle>Настройки — GlucoTrack</PageTitle>

<div style="max-width:600px">
    <div class="home-date-bar">
        <h2 style="margin:0;font-size:1.25rem;font-weight:700">Настройки</h2>
    </div>

    <div class="home-card" style="margin-bottom:1rem">
        <div class="home-card-title">Профиль и параметры лечения</div>
        <p style="font-size:.875rem;color:var(--c-text-muted);margin-bottom:1rem">
            Личные данные, инсулины, цели питания и глюкозы, коэффициенты IC/ISF — всё в одном месте.
        </p>
        <button class="btn btn-primary" @onclick='() => Nav.NavigateTo("/profile")'>
            Перейти в профиль
        </button>
    </div>

    @if (_loading) { <p style="color:var(--c-text-muted)">Загрузка...</p> }
    else
    {
        <div class="home-card" style="margin-bottom:1rem">
            <div class="home-card-title">Аккаунт</div>
            <div style="font-size:.875rem;color:var(--c-text-muted)">
                Для смены пароля или удаления аккаунта обратитесь к администратору.
            </div>
        </div>
    }
</div>

@code {
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        await Task.CompletedTask;
        _loading = false;
    }
}
